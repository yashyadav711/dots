{
  "permissions": {
    "allow": [
      "Bash(*)"
    ],
    "defaultMode": "dontAsk"
  },
    "_p4_safety_note": "P4 enforcement needs BOTH layers. (1) PreToolUse hooks below catch the harness-issued command. (2) MANDATORY per-repo git pre-commit hook is the real P3 defense (H1: PreToolUse fires before `git add`, so `git add x && git commit` stages nothing at check time). On heydaddy, mirror, AND nhq-agentic-os install it: printf '#!/bin/sh\\nexec ~/.local/bin/nhq-p3-guard pre-commit\\n' > <repo>/.git/hooks/pre-commit && chmod +x <repo>/.git/hooks/pre-commit . The pre-commit gate never trusts inline env (H2).",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/yash/.claude/hooks/dangerous-command-guard.sh"
          },
          {
            "type": "command",
            "command": "/home/yash/.local/bin/nhq-p3-guard"
          }
        ]
      },
      {
        "matcher": "mcp__.*railway.*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/yash/.local/bin/mcp-write-guard"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "setsid bash /home/yash/Github/envy/auto-sync.sh >/dev/null 2>&1 </dev/null &"
          },
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty 2>/dev/null || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); printf '[%s@%s %s]' \"$(whoami)\" \"$(hostname -s)\" \"$(basename \"$(echo \"$input\" | jq -r '.workspace.current_dir')\")\""
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "firecrawl@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "atomic-agents@claude-plugins-official": true,
    "railway@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "editorMode": "normal",
  "preferredNotifChannel": "kitty",
  "autoCompactEnabled": true,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true
}
