<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="catppuccin-mocha" _name="Catppuccin Mocha" version="1.0">
  <author>Catppuccin</author>
  <_description>Soothing pastel theme — Mocha flavor</_description>

  <!-- Catppuccin Mocha Palette -->
  <color name="base"       value="#1e1e2e"/>
  <color name="mantle"     value="#181825"/>
  <color name="crust"      value="#11111b"/>
  <color name="surface0"   value="#313244"/>
  <color name="surface1"   value="#45475a"/>
  <color name="surface2"   value="#585b70"/>
  <color name="overlay0"   value="#6c7086"/>
  <color name="overlay1"   value="#7f849c"/>
  <color name="overlay2"   value="#9399b2"/>
  <color name="subtext0"   value="#a6adc8"/>
  <color name="subtext1"   value="#bac2de"/>
  <color name="text"       value="#cdd6f4"/>
  <color name="rosewater"  value="#f5e0dc"/>
  <color name="flamingo"   value="#f2cdcd"/>
  <color name="pink"       value="#f5c2e7"/>
  <color name="mauve"      value="#cba6f7"/>
  <color name="red"        value="#f38ba8"/>
  <color name="maroon"     value="#eba0ac"/>
  <color name="peach"      value="#fab387"/>
  <color name="yellow"     value="#f9e2af"/>
  <color name="green"      value="#a6e3a1"/>
  <color name="teal"       value="#94e2d5"/>
  <color name="sky"        value="#89dceb"/>
  <color name="sapphire"   value="#74c7ec"/>
  <color name="blue"       value="#89b4fa"/>
  <color name="lavender"   value="#b4befe"/>

  <!-- Global -->
  <style name="text"                   foreground="text"     background="base"/>
  <style name="selection"              foreground="text"     background="surface1"/>
  <style name="cursor"                 foreground="rosewater"/>
  <style name="secondary-cursor"       foreground="flamingo"/>
  <style name="current-line"           background="surface0"/>
  <style name="line-numbers"           foreground="surface1" background="mantle"/>
  <style name="current-line-number"    foreground="subtext0" background="mantle" bold="true"/>
  <style name="draw-spaces"            foreground="surface1"/>
  <style name="background-pattern"     background="mantle"/>
  <style name="right-margin"           foreground="overlay0" background="surface0"/>
  <style name="search-match"           foreground="base"     background="yellow"/>
  <style name="bracket-match"          foreground="peach"    bold="true"/>
  <style name="bracket-mismatch"       foreground="red"      bold="true"/>

  <!-- Comments -->
  <style name="def:comment"            foreground="overlay1"/>
  <style name="def:shebang"            foreground="overlay1" bold="true"/>
  <style name="def:doc-comment-element" italic="true"/>

  <!-- Constants -->
  <style name="def:constant"           foreground="peach"/>
  <style name="def:string"             foreground="green"/>
  <style name="def:special-char"       foreground="teal"/>
  <style name="def:special-constant"   foreground="peach"/>
  <style name="def:floating-point"     foreground="peach"/>
  <style name="def:number"             foreground="peach"/>
  <style name="def:boolean"            foreground="peach"/>

  <!-- Identifiers -->
  <style name="def:identifier"         foreground="blue"/>
  <style name="def:function"           foreground="blue"/>
  <style name="def:namespace"          foreground="lavender"/>

  <!-- Statements / Keywords -->
  <style name="def:statement"          foreground="mauve" bold="true"/>
  <style name="def:keyword"            foreground="mauve"/>
  <style name="def:operator"           foreground="sky"/>

  <!-- Types -->
  <style name="def:type"               foreground="yellow"/>
  <style name="def:class"              foreground="yellow" bold="true"/>
  <style name="def:builtin"            foreground="red"/>

  <!-- Markup -->
  <style name="def:emphasis"           italic="true"/>
  <style name="def:strong-emphasis"    foreground="text"   bold="true"/>
  <style name="def:inline-code"        foreground="green"/>
  <style name="def:insertion"          underline="single"/>
  <style name="def:deletion"           strikethrough="true"/>
  <style name="def:link-text"          foreground="blue"/>
  <style name="def:link-symbol"        foreground="overlay0" bold="true"/>
  <style name="def:link-destination"   italic="true" underline="single"/>
  <style name="def:heading"            foreground="mauve"  bold="true"/>
  <style name="def:thematic-break"     foreground="overlay0"/>
  <style name="def:preformatted-section" foreground="green"/>
  <style name="def:list-marker"        foreground="peach"  bold="true"/>

  <!-- Misc -->
  <style name="def:preprocessor"       foreground="pink"/>
  <style name="def:error"              foreground="red"    bold="true"/>
  <style name="def:warning"            foreground="yellow"/>
  <style name="def:note"               foreground="sky"    bold="true"/>
  <style name="def:net-address"        italic="true" underline="single"/>
  <style name="def:variable"           foreground="text"/>

  <!-- Diff -->
  <style name="diff:added-line"        foreground="green"/>
  <style name="diff:removed-line"      foreground="red"/>
  <style name="diff:changed-line"      foreground="yellow"/>
  <style name="diff:diff-file"         foreground="mauve"  bold="true"/>
  <style name="diff:location"          foreground="sapphire"/>
  <style name="diff:special-case"      foreground="text"   bold="true"/>

</style-scheme>
