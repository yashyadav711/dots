#!/usr/bin/env bash
# nhq-spawn <agent> "<task>" — spawn an autonomous, talkable NHQ fleet agent.
#
# Launches an INTERACTIVE `claude --dangerously-skip-permissions` inside a tmux
# session living in the agent's repo dir, then sends the task plus the standard
# FLEET PROTOCOL footer. The agent stays talkable (nhq-tell) and reports back to
# Director when finished (nhq-done — baked into the footer).
#
# Rides Yash's existing Claude subscription via the `claude` CLI. NO API key.
#
# v2: sessions are PERSISTENT + REUSABLE. A spawned session keeps claude running
# idle-at-prompt after a task (talkable via nhq-tell), and nhq-spawn REUSES a live
# fleet-<agent> session instead of spawning a duplicate. It also prints the exact
# `nhq-await` line Director runs to get a real completion notification.
#
# Usage: nhq-spawn heydaddy "Add retry logic to the upload queue"
set -euo pipefail

SELF="$(readlink -f "${BASH_SOURCE[0]:-$0}")"
# shellcheck source=/dev/null
source "$(dirname "$SELF")/nhq-lib.sh"

AGENT="${1:-}"
TASK="${2:-}"

if [[ -z "$AGENT" || -z "$TASK" ]]; then
  echo "usage: nhq-spawn <heydaddy|mirror|envy|director> \"<task>\"" >&2
  exit 1
fi

# Map agent -> repo dir
case "$AGENT" in
  heydaddy) REPO="$HOME/Github/heydaddy" ;;
  mirror)   REPO="$HOME/Github/mirror" ;;
  envy)     REPO="$HOME/Github/envy" ;;
  director) REPO="$HOME/Github/product-manager" ;;
  *)
    echo "nhq-spawn: unknown agent '$AGENT' (want heydaddy|mirror|envy|director)" >&2
    exit 1
    ;;
esac

if [[ ! -d "$REPO" ]]; then
  echo "nhq-spawn: repo dir not found: $REPO" >&2
  exit 1
fi

CLAUDE_BIN="$HOME/.local/bin/claude"
if [[ ! -x "$CLAUDE_BIN" ]]; then
  echo "nhq-spawn: claude CLI not found at $CLAUDE_BIN" >&2
  exit 1
fi

# Standard FLEET PROTOCOL footer (agent name baked in for the callback)
FOOTER="--- FLEET PROTOCOL: You are an autonomous NHQ fleet agent. BRANCHES ONLY — no push, no merge, no deploy unless Yash explicitly says so. Surgical changes; flag Protocol-3 (auth/payments/PII/security), don't silently commit it. Keep a live progress file in this repo's ai/ dir. MANDATORY LAST STEP — your task is NOT complete until you do this: when you finish (or are blocked), you MUST run: nhq-done ${AGENT} \"<one-paragraph result: what you did / blocked-on / branch>\". This is the ONLY way your result reaches Director — there is no other return path. If you finish and go idle WITHOUT calling nhq-done, you have silently failed to report, no matter how good the work was. Do not end the task by any other means; calling nhq-done is the final action, every time."

MESSAGE="${TASK} ${FOOTER}"

# ── REUSE (v2): if a live fleet-<agent> session already exists, send the new task
# into it instead of spawning a duplicate claude (RAM-aware; one agent, one claude).
# Prefer an IDLE session (claude at its prompt) over a RUNNING one. DEAD sessions
# (dropped to fish) are skipped — we spawn fresh below.
REUSE=""
while IFS= read -r s; do
  [[ -z "$s" ]] && continue
  st="$(nhq_session_state "$s")"
  if [[ "$st" == "IDLE" ]]; then REUSE="$s"; break; fi
  [[ "$st" == "RUNNING" && -z "$REUSE" ]] && REUSE="$s"
done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -E "^fleet-${AGENT}(-|\$)" || true)

if [[ -n "$REUSE" ]]; then
  rm -f "$(nhq_marker "$REUSE")"          # clear any stale report so nhq-await waits for THIS task
  nhq_touch_activity "$REUSE"
  "$HOME/.local/bin/nhq-tell" "$REUSE" "$MESSAGE" >/dev/null
  echo "reused: $REUSE  (agent=$AGENT  was=${st})  — sent task via nhq-tell"
  echo "  watch:  tmux attach -t $REUSE"
  echo "  talk:   nhq-tell $REUSE '<msg>'"
  echo "  await:  nhq-await $REUSE"
  exit 0
fi

# Short slug from the task for the session name
SLUG=$(printf '%s' "$TASK" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9' '-' \
  | sed 's/--*/-/g; s/^-//; s/-$//' | cut -c1-24)
SLUG="${SLUG:-task}"
SESSION="fleet-${AGENT}-${SLUG}"

# If a session by this exact name already exists (DEAD/at-fish), suffix a counter
BASE="$SESSION"; N=2
while tmux has-session -t "$SESSION" 2>/dev/null; do
  SESSION="${BASE}-${N}"; N=$((N + 1))
done

# Fresh task → no stale report; start the activity clock for the reaper.
rm -f "$(nhq_marker "$SESSION")"
nhq_touch_activity "$SESSION"

# Launch interactive claude in a detached tmux session, in the repo dir. The
# trailing `exec fish` is a safety net: if claude ever exits/crashes, the tmux
# session survives (inspectable, shows DEAD) instead of vanishing. Interactive
# claude itself stays alive idle-at-prompt after a task — that's the talkable
# persistence; this just keeps the pane from disappearing on an unexpected exit.
tmux new-session -d -s "$SESSION" -c "$REPO" \
  "$CLAUDE_BIN --dangerously-skip-permissions; exec fish"

# Wait for claude (node) to boot before sending the task. Poll the pane's
# current command until it's no longer a bare shell, capped at ~30s.
booted=0
for _ in $(seq 1 60); do
  cmd=$(tmux display-message -p -t "$SESSION" '#{pane_current_command}' 2>/dev/null || echo "")
  case "$cmd" in
    fish|bash|sh|zsh|"") sleep 0.5 ;;
    *) booted=1; break ;;
  esac
done
# Settle so the TUI is ready to accept input
sleep 3

if [[ "$booted" -eq 0 ]]; then
  echo "nhq-spawn: warning — claude pane didn't look booted; sending task anyway." >&2
fi

# Send the task as a single literal line, then Enter (0.3s apart so the TUI
# registers the paste before submit)
tmux send-keys -t "$SESSION" -l -- "$MESSAGE"
sleep 0.4
tmux send-keys -t "$SESSION" Enter

# CONFIRM-SUBMIT: on a RAM-loaded boot the TUI can be slow to wire up its input
# widget, so the first Enter sometimes lands as a no-op (the task sits typed-but-
# unsubmitted). Use the reliable v2 state detector: if claude doesn't go RUNNING
# shortly, the message is still in the box — re-press Enter until it submits.
for _ in 1 2 3 4 5 6; do
  sleep 2
  [[ "$(nhq_session_state "$SESSION")" == "RUNNING" ]] && break
  tmux send-keys -t "$SESSION" Enter
done

echo "spawned: $SESSION  (agent=$AGENT  repo=$REPO)"
echo "  watch:  tmux attach -t $SESSION"
echo "  talk:   nhq-tell $SESSION '<msg>'"
echo "  await:  nhq-await $SESSION"
