#!/usr/bin/env python3
"""agy-snapshot — append per-account quota snapshot row to usage-history.csv."""
import csv, json, os, datetime, urllib.request, sys

URL      = "http://localhost:51200/api/status"
CSV_PATH = os.path.expanduser("~/.pi-antigravity-rotator/usage-history.csv")
MODELS   = ["claude-opus-4-6-thinking", "gemini-3.1-pro", "gemini-3.5-flash"]
HEADER   = ["timestamp", "email", "status", "total_requests",
            "quota_claude", "quota_gemini_pro", "quota_gemini_flash"]

try:
    data = json.loads(urllib.request.urlopen(URL, timeout=5).read())
except Exception as e:
    print(f"[agy-snapshot] Cannot reach rotator: {e}", file=sys.stderr)
    sys.exit(1)

ts = datetime.datetime.now(datetime.UTC).strftime("%Y-%m-%dT%H:%M:%SZ")
write_header = not os.path.exists(CSV_PATH) or os.path.getsize(CSV_PATH) == 0

with open(CSV_PATH, "a", newline="") as f:
    w = csv.writer(f)
    if write_header:
        w.writerow(HEADER)
    for acc in data.get("accounts", []):
        qmap = {q["modelKey"]: q["percentRemaining"] for q in acc.get("quota", [])}
        w.writerow([
            ts,
            acc["email"],
            acc["status"],
            acc["totalRequests"],
            qmap.get("claude-opus-4-6-thinking", ""),
            qmap.get("gemini-3.1-pro", ""),
            qmap.get("gemini-3.5-flash", ""),
        ])

print(f"[agy-snapshot] {ts}  {len(data.get('accounts', []))} accounts logged → {CSV_PATH}")
