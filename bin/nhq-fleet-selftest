echo "── SEC-C1: self-approval bypass closed (UUID commitment, SHA256) ───────"
# Execute the guard (main) hermetically: isolated token dir + captured notification.
GUARD="$BIN/../claude/hooks/dangerous-command-guard.sh"
C1DIR="$TMP/c1"; C1NL="$TMP/c1-notif.log"
C1NS="$TMP/c1-notify"; printf '#!/usr/bin/env bash\necho "$@" >> "%s"\n' "$C1NL" > "$C1NS"; chmod +x "$C1NS"
c1run() { printf '{"tool_name":"Bash","session_id":"sx","tool_input":{"command":"railway up"}}' \
  | env CLAUDE_DANGEROUS_DIR="$C1DIR" NHQ_NOTIFY="$C1NS" bash "$GUARD"; }
o1="$(c1run)"
grep -q '"deny"' <<<"$o1" && ok "C1: dangerous cmd denied on first block" || no "C1: first block not denied"
PFILE="$(ls "$C1DIR"/pending/*.json 2>/dev/null | head -1)"; PJSON="$(cat "$PFILE" 2>/dev/null)"
# NEGATIVE: forge approvals from every value the agent can read in the pending JSON (+cmdhash)
for v in $(jq -r '.. | strings' "$PFILE" 2>/dev/null); do touch "$C1DIR/approved/$v" 2>/dev/null; done
touch "$C1DIR/approved/$(basename "$PFILE" .json)" 2>/dev/null
o2="$(c1run)"
grep -q '"deny"' <<<"$o2" && ok "C1: forged approvals from pending JSON still DENIED" || no "C1: SELF-APPROVAL BYPASS"
# POSITIVE: only the real UUID (notification-only) approves
rm -f "$C1DIR"/approved/* 2>/dev/null
C1U="$(grep -oE '[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}' "$C1NL" | head -1)"
touch "$C1DIR/approved/$C1U"
o3="$(c1run)"
grep -q '"deny"' <<<"$o3" && no "C1: real UUID failed to approve" || ok "C1: real notification UUID approves"
if grep -q "$C1U" <<<"$PJSON"; then no "C1: uuid leaked into agent-readable JSON"; else ok "C1: uuid absent from pending JSON"; fi

