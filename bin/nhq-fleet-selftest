eq "set_variables → routine" "$("$MG" classify mcp__plugin_railway_railway__set_variables)" "routine"
eq "list_services → read"   "$("$MG" classify mcp__plugin_railway_railway__list_services)"  "read"
eq "non-railway tool → ignore" "$("$MG" classify Bash)" "ignore"
mcpc() { if "$@" >/dev/null 2>&1; then echo allow; else echo deny; fi; }
eq "irreversible w/o token → DENY" "$(mcpc env NHQ_AUDIT_BIN=/bin/true "$MG" check mcp__plugin_railway_railway__remove_volume)" "deny"
eq "irreversible w/ token → ALLOW" "$(mcpc env NHQ_AUDIT_BIN=/bin/true VFRAME_MCP_OK=1 "$MG" check mcp__plugin_railway_railway__remove_volume)" "allow"
