echo "── P5-c: nhq-ctx — background-leak scan (lingering/stale cards) ────────"
# shellcheck source=/dev/null
source "$BIN/nhq-ctx"                  # source-guarded → exposes ctx_collect
nhq_session_state() { echo DEAD; }     # all sessions dead → markers linger
nhq_session_state_full() { echo IDLE; } # no ORPHANs in this fixture
CTXD="$TMP/ctx-state"; mkdir -p "$CTXD"
