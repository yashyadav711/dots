#!/usr/bin/env bash
# nhq-fleet-selftest — proves the two Fleet Kit notify-back hardening fixes:
#   Bug 1  nhq-await must NOT false-fire on a stale/leftover marker, but MUST fire
#          on a marker written after (or in the re-arm hand-off just before) arm.
#   Bug 2  nhq-reap must SPARE an idle session whose repo has uncommitted work or
#          recent activity, while still reaping a clean+quiet repo.
#
# Hermetic: runs entirely against a throwaway $NHQ_STATE_DIR and temp git repos.
# tmux-dependent subtests self-skip if tmux is unavailable.
#
# Usage: nhq-fleet-selftest        (exits non-zero if any assertion fails)
set -uo pipefail

BIN="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]:-$0}")")" && pwd)"
TMP="$(mktemp -d)"
trap 'rm -rf "$TMP"; tmux kill-session -t fleet-selftest-fresh 2>/dev/null || true' EXIT

export NHQ_STATE_DIR="$TMP/state"
mkdir -p "$NHQ_STATE_DIR"

pass=0; fail=0
ok() { echo "  PASS: $1"; pass=$((pass + 1)); }
no() { echo "  FAIL: $1"; fail=$((fail + 1)); }
status_of() { grep -o 'NHQ-AWAIT-STATUS: .*' <<<"$1" | tail -1; }

echo "── Bug 1: nhq-await stale-marker handling ──────────────────────────────"

# 1a. A stale leftover marker (10 min old) on a session that no longer exists must
#     NOT print REPORTED — under the bug it returned exit 0 / REPORTED immediately.
S1="fleet-selftest-stale"
M1="$NHQ_STATE_DIR/${S1}.done"
echo "## leftover report from a prior run" > "$M1"
touch -d "10 minutes ago" "$M1"
out="$("$BIN/nhq-await" "$S1" --timeout 2 --poll 1 2>&1 || true)"
if grep -q "NHQ-AWAIT-STATUS: REPORTED" <<<"$out"; then
  no "stale marker false-fired REPORTED"
else
  ok "stale marker did not false-fire ($(status_of "$out"))"
fi

# 1b. A FRESH marker written after arm must fire REPORTED. Needs a live session so
#     await doesn't GONE-exit first; a dummy tmux session (sleep) satisfies the
#     has-session check. Self-skips if tmux is unavailable.
if command -v tmux >/dev/null 2>&1; then
  S2="fleet-selftest-fresh"
  M2="$NHQ_STATE_DIR/${S2}.done"
  rm -f "$M2"
  tmux kill-session -t "$S2" 2>/dev/null || true
  tmux new-session -d -s "$S2" "sleep 60" 2>/dev/null || true
  ( sleep 1; echo "## fresh report for THIS task" > "$M2" ) &
  out="$("$BIN/nhq-await" "$S2" --timeout 6 --poll 1 2>&1 || true)"
  tmux kill-session -t "$S2" 2>/dev/null || true
  if grep -q "NHQ-AWAIT-STATUS: REPORTED" <<<"$out"; then
    ok "fresh marker fired REPORTED"
  else
    no "fresh marker did NOT fire ($(status_of "$out"))"
  fi
else
  echo "  SKIP: 1b fresh-marker fire (tmux unavailable)"
fi

echo "── Bug 2: nhq-reap work-loss guard ─────────────────────────────────────"

# Expose the reap helpers without walking live tmux sessions (source guard).
# shellcheck source=/dev/null
source "$BIN/nhq-reap"
set +e   # nhq-reap sets -e on source; the harness tolerates assertion failures

git_quiet() { git -C "$1" -c user.email=t@t -c user.name=t -c commit.gpgsign=false "${@:2}" >/dev/null 2>&1; }

# 2a. Uncommitted work => protected (spared).
RD="$TMP/dirty"; git init -q "$RD"; echo "work in progress" > "$RD/file.txt"
if reason="$(nhq_reap_protected "$RD")"; then
  ok "uncommitted tree => SPARED ($reason)"
else
  no "uncommitted tree was NOT spared"
fi

# 2b. Clean + quiet (old) repo => reapable (not protected).
RC="$TMP/clean"; git init -q "$RC"; echo committed > "$RC/file.txt"
git_quiet "$RC" add -A; git_quiet "$RC" commit -m init
# backdate everything outside .git past the recency window
find "$RC" -path '*/.git' -prune -o -print0 2>/dev/null | xargs -0 touch -d "30 minutes ago" 2>/dev/null
if reason="$(nhq_reap_protected "$RC")"; then
  no "clean+old tree was wrongly spared ($reason)"
else
  ok "clean+old tree => reapable"
fi

# 2c. Clean but recently modified => protected (spared).
RR="$TMP/recent"; git init -q "$RR"; echo committed > "$RR/file.txt"
git_quiet "$RR" add -A; git_quiet "$RR" commit -m init
touch "$RR/file.txt"   # fresh mtime => within recency window
if reason="$(nhq_reap_protected "$RR")"; then
  ok "clean+recent tree => SPARED ($reason)"
else
  no "clean+recent tree was NOT spared"
fi

# 2d. Unknown/unmappable session => repo "" => not protected (idle policy applies).
#     (P1: repo now resolved via the registry accessor, not the old nhq_session_repo.)
if [[ -z "$(nhq_agent_repo "$(nhq_session_agent "fleet-bogusagent-x")")" ]]; then
  ok "unknown agent maps to empty repo (idle policy applies)"
else
  no "unknown agent unexpectedly mapped to a repo"
fi

echo "── P1-a: fleet registry accessors (nhq-lib) ────────────────────────────"
# nhq-reap (sourced above) pulled in nhq-lib, so the registry accessors are live.
# Pin the registry to the worktree copy beside the scripts under test.
export NHQ_REGISTRY="$BIN/fleet-registry.json"

eq() { # eq <label> <got> <want>
  if [[ "$2" == "$3" ]]; then ok "$1 ($2)"; else no "$1 — got '$2' want '$3'"; fi
}
eq "canon hd → heydaddy"            "$(nhq_agent_canon hd)"                       "heydaddy"
eq "canon pm → director"            "$(nhq_agent_canon pm)"                       "director"
eq "canon product-manager → director" "$(nhq_agent_canon product-manager)"       "director"
eq "canon bogus → ''"               "$(nhq_agent_canon bogus)"                    ""
eq "repo director abs dir"          "$(nhq_agent_repo director)"                  "$HOME/Github/nhq-agentic-os"
eq "alias product-manager → director repo" "$(nhq_agent_repo product-manager)"    "$HOME/Github/nhq-agentic-os"
eq "session fleet-director-x-y"     "$(nhq_session_agent fleet-director-x-y)"     "director"
eq "session fleet-product-manager-z" "$(nhq_session_agent fleet-product-manager-z)" "director"

echo "── P1-b: nhq-meta CRUD round-trip ──────────────────────────────────────"
SM="fleet-selftest-meta"
"$BIN/nhq-meta" init "$SM" agent envy agent_name Envy repo "$HOME/Github/envy" \
  task "Add retry cap to the upload queue" model "Claude Sonnet 4.6 (Thinking)" \
  spawn_epoch 1750284000 base_commit abc1234 last_state RUNNING >/dev/null 2>&1
eq "meta get task"        "$("$BIN/nhq-meta" get "$SM" task)"        "Add retry cap to the upload queue"
eq "meta get agent"       "$("$BIN/nhq-meta" get "$SM" agent)"       "envy"
eq "meta get spawn_epoch" "$("$BIN/nhq-meta" get "$SM" spawn_epoch)" "1750284000"
eq "meta get p3_flag (false, not '')" "$("$BIN/nhq-meta" get "$SM" p3_flag)" "false"
"$BIN/nhq-meta" set --json "$SM" tokens_in 500 >/dev/null 2>&1
eq "meta set --json tokens_in → get" "$("$BIN/nhq-meta" get "$SM" tokens_in)" "500"
# atomicity: record still parses as valid JSON after the in-place set
if jq -e . "$NHQ_STATE_DIR/${SM}.meta" >/dev/null 2>&1; then
  ok "meta record is valid JSON after set (atomic)"
else
  no "meta record corrupted after set"
fi

echo "── P1-c: spawn .meta + NHQ_AGENT contract (tmux-gated) ──────────────────"
# Verifies the two mechanisms nhq-spawn relies on, hermetically — WITHOUT booting a
# real claude agent (RAM-heavy on this laptop, and it would launch a live agent).
# (1) the .meta a spawn writes is well-formed with agent==envy; (2) tmux -e exports
# NHQ_AGENT into the session env. Self-skips if tmux is unavailable.
if command -v tmux >/dev/null 2>&1; then
  SS="fleet-selftest-spawnmeta"
  # (1) spawn-shaped .meta write
  "$BIN/nhq-meta" init "$SS" agent envy agent_name Envy repo "$HOME/Github/envy" \
    model "Claude Sonnet 4.6 (Thinking)" spawn_epoch 1 base_commit deadbeef last_state RUNNING >/dev/null 2>&1
  eq "spawn .meta agent==envy" "$("$BIN/nhq-meta" get "$SS" agent)" "envy"
  # (2) tmux -e NHQ_AGENT export (the exact flag nhq-spawn uses on launch)
  tmux kill-session -t "$SS" 2>/dev/null || true
  if tmux new-session -d -s "$SS" -e "NHQ_AGENT=Envy" "sleep 30" 2>/dev/null; then
    got="$(tmux show-environment -t "$SS" NHQ_AGENT 2>/dev/null)"
    eq "tmux session exports NHQ_AGENT" "$got" "NHQ_AGENT=Envy"
    tmux kill-session -t "$SS" 2>/dev/null || true
  else
    echo "  SKIP: P1-c NHQ_AGENT export (tmux new-session -e unsupported here)"
  fi
else
  echo "  SKIP: P1-c spawn-meta/NHQ_AGENT (tmux unavailable)"
fi

echo "── P2-a: nhq-cost sums a known JSONL → .meta ───────────────────────────"
# Known transcript: input 100+200+300=600, output 10+20+30=60 (+ a non-assistant line).
CJ="$NHQ_STATE_DIR/known-session.jsonl"
{
  echo '{"type":"assistant","message":{"model":"claude-sonnet-4-6","usage":{"input_tokens":100,"output_tokens":10,"cache_read_input_tokens":5,"cache_creation_input_tokens":1}}}'
  echo '{"type":"user","message":{"role":"user","content":"hi"}}'
  echo '{"type":"assistant","message":{"model":"claude-sonnet-4-6","usage":{"input_tokens":200,"output_tokens":20}}}'
  echo '{"type":"assistant","message":{"model":"claude-sonnet-4-6","usage":{"input_tokens":300,"output_tokens":30}}}'
} > "$CJ"
SC="fleet-selftest-cost"
"$BIN/nhq-meta" init "$SC" repo "$HOME/Github/envy" model "Claude Sonnet 4.6 (Thinking)" spawn_epoch 1 >/dev/null 2>&1
"$BIN/nhq-meta" set "$SC" jsonl "$CJ" >/dev/null 2>&1   # cache so cost uses our fixture
"$BIN/nhq-cost" "$SC" >/dev/null 2>&1
eq "cost tokens_in == 600"  "$("$BIN/nhq-meta" get "$SC" tokens_in)"  "600"
eq "cost tokens_out == 60"  "$("$BIN/nhq-meta" get "$SC" tokens_out)" "60"
eq "cost_usd == 0.0027"     "$("$BIN/nhq-meta" get "$SC" cost_usd)"   "0.0027"
[[ -n "$("$BIN/nhq-meta" get "$SC" last_cost_ts)" ]] && ok "cost wrote last_cost_ts" || no "cost did not write last_cost_ts"

echo "── P2-b: nhq_session_state_full 7-state resolver ───────────────────────"
# Drive the base state via a mock; markers + a temp repo drive the derived states.
nhq_session_state() { echo "${MOCK_BASE:-IDLE}"; }
SR="$TMP/state_full_repo"; git init -q "$SR"
git_quiet "$SR" commit --allow-empty -m base
SB_COMMIT="$(git -C "$SR" rev-parse HEAD)"

# GHOST: IDLE + fresh .done
SG="fleet-selftest-ghost"; "$BIN/nhq-meta" init "$SG" repo "$SR" base_commit "$SB_COMMIT" >/dev/null 2>&1
: > "$NHQ_STATE_DIR/$SG.done"; MOCK_BASE=IDLE
eq "IDLE + fresh .done → GHOST" "$(nhq_session_state_full "$SG")" "GHOST"

# ORPHAN: IDLE + new commit since base_commit + no .done
SO="fleet-selftest-orphan"; "$BIN/nhq-meta" init "$SO" repo "$SR" base_commit "$SB_COMMIT" >/dev/null 2>&1
git_quiet "$SR" commit --allow-empty -m work   # advances HEAD past base_commit
MOCK_BASE=IDLE
eq "IDLE + new commit + no .done → ORPHAN" "$(nhq_session_state_full "$SO")" "ORPHAN"

# BLOCKED/STALLED markers win over base; pass-through otherwise.
SBL="fleet-selftest-blocked"; "$BIN/nhq-meta" init "$SBL" repo "$SR" base_commit "$(git -C "$SR" rev-parse HEAD)" >/dev/null 2>&1
: > "$NHQ_STATE_DIR/$SBL.blocked"; MOCK_BASE=RUNNING
eq "blocked marker → BLOCKED (over RUNNING)" "$(nhq_session_state_full "$SBL")" "BLOCKED"
SPT="fleet-selftest-passthru"; "$BIN/nhq-meta" init "$SPT" repo "$SR" base_commit "$(git -C "$SR" rev-parse HEAD)" >/dev/null 2>&1
MOCK_BASE=RUNNING
eq "no markers, no new commit → base RUNNING" "$(nhq_session_state_full "$SPT")" "RUNNING"
unset -f nhq_session_state   # restore real resolver for anything downstream

echo "── P2-c: nhq-status modes (mocked sessions) ────────────────────────────"
# shellcheck source=/dev/null
source "$BIN/nhq-status"   # source-guarded → exposes render_* without walking tmux
"$BIN/nhq-meta" init fleet-selftest-run agent_name HeyDaddy task "Add retry cap to the upload queue" >/dev/null 2>&1
"$BIN/nhq-meta" init fleet-selftest-stl agent_name Mirror   task "Fix the audit gap" >/dev/null 2>&1
live_sessions() { printf '%s\n' fleet-selftest-run fleet-selftest-stl; }
nhq_session_state_full() { case "$1" in fleet-selftest-run) echo RUNNING ;; fleet-selftest-stl) echo STALLED ;; *) echo IDLE ;; esac; }
BLK="$(render_block)"
WANT_BLK=$'🔄 RUNNING\n├── HeyDaddy — Add retry cap to the upload queue\n└── Mirror — Fix the audit gap [STALLED]'
eq "--block byte-for-byte RULE -4" "$BLK" "$WANT_BLK"
if render_json | jq -e 'type=="array" and length==2 and (.[0].state=="RUNNING")' >/dev/null 2>&1; then
  ok "--json valid array, RUNNING session present"
else
  no "--json invalid or missing RUNNING session"
fi
# Empty fleet → --block prints nothing.
live_sessions() { printf ''; }
EMPTY="$(render_block)"
eq "empty fleet → empty --block" "${#EMPTY}" "0"
eq "empty fleet → --json is []" "$(render_json)" "[]"

echo "── P2-d: nhq-done logs one ledger row + flips .meta DONE ────────────────"
LED="$TMP/task-ledger.md"; printf '# NHQ Task Ledger\n\n## Ledger (newest first)\n' > "$LED"
DJ="$NHQ_STATE_DIR/done-known.jsonl"
echo '{"type":"assistant","message":{"model":"claude-opus-4-8","usage":{"input_tokens":1000,"output_tokens":200}}}' > "$DJ"
"$BIN/nhq-meta" init fleet-envy agent envy agent_name Envy repo "$HOME/Github/envy" \
  task "P2 OBSERVE build" model "Claude Opus 4.8" spawn_epoch "$(( $(date +%s) - 300 ))" last_state RUNNING >/dev/null 2>&1
"$BIN/nhq-meta" set fleet-envy jsonl "$DJ" >/dev/null 2>&1
# TMUX unset → nhq-done resolves the fallback session fleet-envy; hermetic overrides.
env -u TMUX NHQ_LEDGER="$LED" NHQ_INBOX="$TMP/inbox.md" NHQ_NOTIFY=/bin/true NHQ_STATE_DIR="$NHQ_STATE_DIR" \
  "$BIN/nhq-done" envy "Done: P2 built on feat/aos-v0-p1. No push." >/dev/null 2>&1
eq "ledger has exactly one row" "$(grep -cE '^\| ' "$LED")" "1"
ROW="$(grep -E '^\| ' "$LED")"
if grep -qE '1000\+200 tok · \$0\.0300' <<<"$ROW"; then ok "ledger row carries real tokens + \$cost"; else no "ledger row missing token/cost ($ROW)"; fi
eq "nhq-done flipped .meta last_state=DONE" "$("$BIN/nhq-meta" get fleet-envy last_state)" "DONE"
[[ -n "$("$BIN/nhq-meta" get fleet-envy done_ts)" ]] && ok "nhq-done set done_ts" || no "nhq-done did not set done_ts"

echo "── P3-a: nhq-warden STALLED detection + clear-on-leave ─────────────────"
# Hermetic: base state injected via a stub; no live tmux/claude needed.
STUB="$TMP/state-stub"
cat > "$STUB" <<'EOS'
#!/usr/bin/env bash
f="$NHQ_STATE_DIR/$1.basestate"; [[ -f "$f" ]] && cat "$f" || echo DEAD
EOS
chmod +x "$STUB"
WLOG="$TMP/warden.log"
warden_once() { env NHQ_STATE_DIR="$NHQ_STATE_DIR" NHQ_WARDEN_STATE_CMD="$STUB" \
  NHQ_NOTIFY=/bin/true NHQ_WARDEN_LOG="$WLOG" python3 "$BIN/nhq-warden" --check-fleet-once; }

WR="$TMP/warden-repo"; git init -q "$WR"; git_quiet "$WR" commit --allow-empty -m base
WR_HEAD="$(git -C "$WR" rev-parse HEAD)"
SS="fleet-selftest-stall"
"$BIN/nhq-meta" init "$SS" agent heydaddy repo "$WR" base_commit "$WR_HEAD" \
  spawn_epoch "$(( $(date +%s) - 1900 ))" >/dev/null 2>&1          # spawned 31m ago (> 15m stall_min)
WJ="$NHQ_STATE_DIR/$SS.jsonl"; echo '{}' > "$WJ"; touch -d '10 minutes ago' "$WJ"   # frozen transcript
"$BIN/nhq-meta" set "$SS" jsonl "$WJ" >/dev/null 2>&1
echo RUNNING > "$NHQ_STATE_DIR/$SS.basestate"                       # RUNNING + old + no commit + frozen
warden_once >/dev/null 2>&1
[[ -f "$NHQ_STATE_DIR/$SS.stalled" ]] && ok "warden wrote .stalled (RUNNING+old+no-commit+frozen)" || no "warden did NOT write .stalled"
eq "warden logged one stall ALERT" "$(grep -c 'ALERT \[stall:'"$SS" "$WLOG" 2>/dev/null || echo 0)" "1"
# leave RUNNING → .stalled cleared
echo IDLE > "$NHQ_STATE_DIR/$SS.basestate"
warden_once >/dev/null 2>&1
[[ ! -f "$NHQ_STATE_DIR/$SS.stalled" ]] && ok "warden cleared .stalled on leave-RUNNING" || no "warden did NOT clear .stalled"

echo "── P3-b: nhq-warden silent-complete / ORPHAN ──────────────────────────"
OR="$TMP/orphan-repo"; git init -q "$OR"; git_quiet "$OR" commit --allow-empty -m base
OR_BASE="$(git -C "$OR" rev-parse HEAD)"
SOR="fleet-selftest-orphan"
"$BIN/nhq-meta" init "$SOR" agent mirror repo "$OR" base_commit "$OR_BASE" \
  spawn_epoch "$(( $(date +%s) - 600 ))" >/dev/null 2>&1
git_quiet "$OR" commit --allow-empty -m work                        # HEAD now past base_commit
echo IDLE > "$NHQ_STATE_DIR/$SOR.basestate"                         # IDLE + new commit + no .done
: > "$WLOG"   # fresh log so the count is unambiguous
warden_once >/dev/null 2>&1
eq "warden logged ORPHAN alert" "$(grep -c 'ALERT \[orphan:'"$SOR" "$WLOG" 2>/dev/null || echo 0)" "1"
[[ ! -f "$NHQ_STATE_DIR/$SOR.stalled" ]] && ok "ORPHAN writes no .stalled" || no "ORPHAN wrongly wrote .stalled"

echo "── P3-c: nhq-blocked → .blocked + inbox + nhq-await BLOCKED ─────────────"
BINB="$TMP/inbox-blocked.md"
"$BIN/nhq-meta" init fleet-mirror agent mirror agent_name Mirror repo "$HOME/Github/mirror" \
  task "wire vertex" last_state RUNNING >/dev/null 2>&1
env -u TMUX NHQ_INBOX="$BINB" NHQ_NOTIFY=/bin/true NHQ_STATE_DIR="$NHQ_STATE_DIR" \
  "$BIN/nhq-blocked" mirror "Need the GCP service-account JSON." >/dev/null 2>&1
[[ -f "$NHQ_STATE_DIR/fleet-mirror.blocked" ]] && ok "nhq-blocked wrote .blocked marker" || no "nhq-blocked did not write .blocked"
grep -q '^BLOCKED: ' "$BINB" && ok "nhq-blocked tagged inbox 'BLOCKED:'" || no "inbox missing BLOCKED: tag"
eq "nhq-blocked flipped .meta last_state" "$("$BIN/nhq-meta" get fleet-mirror last_state)" "BLOCKED"
bout="$("$BIN/nhq-await" fleet-mirror --timeout 3 --poll 1 2>&1 || true)"
eq "nhq-await → BLOCKED" "$(status_of "$bout")" "NHQ-AWAIT-STATUS: BLOCKED"

echo "── P3-d: nhq-await typed outcomes + stale guard ────────────────────────"
# .stalled → STALLED exit 0
SD1="fleet-selftest-awaitstall"; echo "## now"$'\n'"no progress" > "$NHQ_STATE_DIR/$SD1.stalled"
o1="$("$BIN/nhq-await" "$SD1" --timeout 3 --poll 1 2>&1 || true)"
eq "fresh .stalled → STALLED" "$(status_of "$o1")" "NHQ-AWAIT-STATUS: STALLED"
# .done → REPORTED + DONE alias both present
SD2="fleet-selftest-awaitdone"; echo "## now"$'\n'"all good" > "$NHQ_STATE_DIR/$SD2.done"
o2="$("$BIN/nhq-await" "$SD2" --timeout 3 --poll 1 2>&1 || true)"
if grep -q 'NHQ-AWAIT-STATUS: REPORTED' <<<"$o2" && grep -q 'NHQ-AWAIT-STATUS: DONE' <<<"$o2"; then
  ok "fresh .done → REPORTED + DONE alias"
else
  no "fresh .done missing REPORTED/DONE ($(status_of "$o2"))"
fi
# priority: .blocked outranks .done
SD3="fleet-selftest-awaitprio"; echo x > "$NHQ_STATE_DIR/$SD3.done"; echo y > "$NHQ_STATE_DIR/$SD3.blocked"
o3="$("$BIN/nhq-await" "$SD3" --timeout 3 --poll 1 2>&1 || true)"
eq ".blocked outranks .done" "$(status_of "$o3")" "NHQ-AWAIT-STATUS: BLOCKED"
# stale .stalled (old) must NOT false-fire
SD4="fleet-selftest-awaitstale"; echo z > "$NHQ_STATE_DIR/$SD4.stalled"; touch -d '5 minutes ago' "$NHQ_STATE_DIR/$SD4.stalled"
o4="$("$BIN/nhq-await" "$SD4" --timeout 2 --poll 1 2>&1 || true)"
if grep -q 'STALLED' <<<"$(status_of "$o4")"; then no "stale .stalled false-fired"; else ok "stale .stalled did not false-fire ($(status_of "$o4"))"; fi

echo "────────────────────────────────────────────────────────────────────────"
echo "nhq-fleet-selftest: ${pass} passed, ${fail} failed"
[[ "$fail" -eq 0 ]]
