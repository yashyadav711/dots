echo "── SEC-H1/H2/H3: nhq-p3-guard bypasses closed ──────────────────────────"
# reuse the P4-b fixture policy file ($P3PF) + git_quiet
p3c() { # p3c <repo> <mode> [env=val...] → echoes allow|deny
  local repo="$1" mode="$2"; shift 2
  if env NHQ_P3_PATHS="$P3PF" NHQ_AUDIT_BIN=/bin/true "$@" "$BIN/nhq-p3-guard" check "$repo" "$mode" >/dev/null 2>&1; then echo allow; else echo deny; fi
}
pre_decision() { # pre_decision <full-bash-cmd> → echoes allow|deny for a PreToolUse fleet-agent commit
  local j out; j="$(jq -nc --arg c "$1" '{tool_name:"Bash",session_id:"s",cwd:"/tmp",tool_input:{command:$c}}')"
  out="$(echo "$j" | env NHQ_P3_PATHS="$P3PF" NHQ_AUDIT_BIN=/bin/true NHQ_AGENT=Envy NHQ_SESSION=fleet-envy-x "$BIN/nhq-p3-guard")"
  if grep -q '"deny"' <<<"$out"; then echo deny; else echo allow; fi
}
SECR="$TMP/sec-p3repo"; git init -q "$SECR"; git_quiet "$SECR" commit --allow-empty -m base
echo "SECRET=1" > "$SECR/.env"; git_quiet "$SECR" add .env
# H2: pre-commit mode never trusts inline env (spoofed director+token still blocked)
eq "H2: pre-commit + spoofed director/token → DENY" "$(p3c "$SECR" precommit NHQ_AGENT=director NHQ_SESSION= VFRAME_P3_OK=1)" "deny"
eq "H2: (control) pretooluse + director/token → ALLOW" "$(p3c "$SECR" pretooluse NHQ_AGENT=Director NHQ_SESSION=main VFRAME_P3_OK=1)" "allow"
# H1: the pre-commit hook is the real defense for the staging-timing gap
env NHQ_P3_PATHS="$P3PF" NHQ_AUDIT_BIN=/bin/true NHQ_AGENT=Envy NHQ_SESSION=fleet-envy-x \
  bash -c 'cd "$1" && "$2" pre-commit' _ "$SECR" "$BIN/nhq-p3-guard" >/dev/null 2>&1 && r=allow || r=deny
eq "H1: pre-commit hook DENIES staged p3 (real defense vs add&&commit)" "$r" "deny"
# H3: GIT_DIR= and inline-env git commit are detected + validated
eq "H3: GIT_DIR= git commit detected → deny"        "$(pre_decision "GIT_DIR=$SECR/.git git commit -m x")"        "deny"
eq "H3: leading-env + GIT_DIR= still detected → deny" "$(pre_decision "FOO=1 GIT_DIR=$SECR/.git git commit -m x")" "deny"
eq "H3: bogus GIT_DIR → fail-closed deny"            "$(pre_decision "GIT_DIR=/nonexistent/.git git commit -m x")" "deny"

echo "── SEC-M3: mcp-write-guard generic hard pattern (no fail-open) ─────────"
eq "M3: remove_environment → hard" "$("$BIN/mcp-write-guard" classify mcp__plugin_railway_railway__remove_environment)" "hard"
eq "M3: wipe_data → hard"          "$("$BIN/mcp-write-guard" classify mcp__plugin_railway_railway__wipe_data)"          "hard"
eq "M3: reset_project → hard"      "$("$BIN/mcp-write-guard" classify mcp__plugin_railway_railway__reset_project)"      "hard"

echo "────────────────────────────────────────────────────────────────────────"
echo "nhq-fleet-selftest: ${pass} passed, ${fail} failed"
[[ "$fail" -eq 0 ]]
