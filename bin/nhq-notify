#!/bin/bash
# nhq-notify <type> <title> <body> — unified NetrunnersHQ desktop notifier.
#
# Consistent house style: a small "Claude Code" app label, then a BIG WHITE bold
# headline + detail in the BODY (dunst only renders Pango markup in the body, not the
# summary — putting text there avoids leaked <span> tags). Frame color is per-type
# (Catppuccin Mocha). Inline markup + dunst color hints survive HyDE dunstrc regen,
# so this needs no dunstrc edits.
#
# Usage:  nhq-notify needs-you "🔴 PM needs you" "Gate 3 test · Mirror merge"
#         nhq-notify deploy    "🚀 Shipped"       "HeyDaddy PR #42 → prod"

# Test-hygiene: suppress ALL desktop toasts when running under the selftest / CI, so
# fixtures never fire real dunst popups at Yash. Honored even by hardcoded-path callers
# (guards) because they all invoke THIS binary. Set NHQ_NOTIFY_SUPPRESS=1 or NHQ_TEST=1.
if [ "${NHQ_NOTIFY_SUPPRESS:-}" = "1" ] || [ "${NHQ_TEST:-}" = "1" ]; then
  exit 0
fi

TYPE="${1:-info}"
TITLE="${2:-NHQ}"
BODY="${3:-}"

# Test/selftest suppression — exit silently (no real desktop toast) when either the
# NHQ_NOTIFY_SUPPRESS/NHQ_TEST env is set (per-run, e.g. selftest fixtures) OR the
# mute-file /tmp/nhq-notify-mute exists (a global kill-switch Director flips during a
# build window so guard-under-test runs don't spam the desktop). Normal operation
# (env unset + no mute file) is unchanged. (Yash 2026-06-19.)
if [ -n "${NHQ_NOTIFY_SUPPRESS:-}${NHQ_TEST:-}" ] || [ -f /tmp/nhq-notify-mute ]; then exit 0; fi

case "$TYPE" in
  needs-you) FR="#f38ba8"; IC="dialog-information";       T=12000 ;;  # 🔴 action needed
  blocked)   FR="#fab387"; IC="dialog-warning";           T=8000  ;;  # 🛑 guard blocked
  done)      FR="#a6e3a1"; IC="emblem-default";           T=6000  ;;  # ✅ task/relay finished
  deploy)    FR="#89b4fa"; IC="emblem-shared";            T=10000 ;;  # 🚀 shipped / merged
  julian)    FR="#cba6f7"; IC="mail-message-new";         T=15000 ;;  # 💬 Julian message
  quota)     FR="#f9e2af"; IC="utilities-system-monitor"; T=10000 ;;  # 📊 usage / quota
  warden)    FR="#eba0ac"; IC="dialog-error";             T=15000 ;;  # ⚠️ system/fleet anomaly
  deadline)  FR="#89dceb"; IC="x-office-calendar";        T=12000 ;;  # 📅 deadline approaching
  secret)    FR="#b4befe"; IC="dialog-password";          T=10000 ;;  # 🔐 secret clipboard
  reply)     FR="#74c7ec"; IC="dialog-information";        T=6000  ;;  # 💬 Claude replied (per-agent, Stop hook)
  *)         FR="#cdd6f4"; IC="dialog-information";        T=8000  ;;  # default / info
esac

if [ -n "$BODY" ]; then
  MSG="<span size='200%' foreground='#ffffff'><b>$TITLE</b>
$BODY</span>"
else
  MSG="<span size='200%' foreground='#ffffff'><b>$TITLE</b></span>"
fi

# ── Session-bus / display recovery ────────────────────────────────────────────
# Fleet notifications fire from detached pollers (nhq-await's setsid poller),
# long-lived daemons (nhq-warden, claude-oom-guard), cron, and hook subprocesses
# whose environment was stripped of the user session vars. With no session bus
# (and no display for D-Bus autolaunch) notify-send dies "Cannot autolaunch D-Bus
# without X11 $DISPLAY" and the toast silently never reaches Yash — every caller
# swallows the failure with `2>/dev/null || true`. Re-establish the session vars
# deterministically so the notifier works no matter who invoked it.
uid="$(id -u)"
: "${XDG_RUNTIME_DIR:=/run/user/$uid}"; export XDG_RUNTIME_DIR
if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ] && [ -S "$XDG_RUNTIME_DIR/bus" ]; then
  export DBUS_SESSION_BUS_ADDRESS="unix:path=$XDG_RUNTIME_DIR/bus"
fi
# Still missing a bus or any display? Harvest the real values from the running
# dunst process (same user) — by definition it is already wired to the live
# graphical session we want the toast to land on.
if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ] || { [ -z "${DISPLAY:-}" ] && [ -z "${WAYLAND_DISPLAY:-}" ]; }; then
  for pid in $(pgrep -u "$uid" -x dunst 2>/dev/null); do
    [ -r "/proc/$pid/environ" ] || continue
    while IFS= read -r -d '' kv; do
      case "$kv" in
        DBUS_SESSION_BUS_ADDRESS=*) [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ] && export "$kv" ;;
        DISPLAY=*)                  [ -z "${DISPLAY:-}" ]                  && export "$kv" ;;
        WAYLAND_DISPLAY=*)          [ -z "${WAYLAND_DISPLAY:-}" ]          && export "$kv" ;;
      esac
    done < "/proc/$pid/environ"
    break
  done
fi

# Fire the toast. notify-send (libnotify, honored by dunst) is primary; if it
# fails, fall back to dunstify directly. Log a failed delivery so a silent miss is
# diagnosable instead of vanishing into the callers' `2>/dev/null`.
NOTIFY_LOG="${NHQ_NOTIFY_LOG:-$XDG_RUNTIME_DIR/nhq-notify.log}"
if notify-send "Claude Code" "$MSG" \
     --urgency=normal --expire-time="$T" \
     --hint string:frcolor:"$FR" -i "$IC" 2>>"$NOTIFY_LOG"; then
  exit 0
fi
if command -v dunstify >/dev/null 2>&1 && \
   dunstify -a "Claude Code" -u normal -t "$T" \
     -h string:frcolor:"$FR" -i "$IC" "Claude Code" "$MSG" 2>>"$NOTIFY_LOG"; then
  exit 0
fi
printf '%s nhq-notify FAILED type=%s title=%q (bus=%s display=%s/%s)\n' \
  "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$TYPE" "$TITLE" \
  "${DBUS_SESSION_BUS_ADDRESS:-unset}" "${DISPLAY:-unset}" "${WAYLAND_DISPLAY:-unset}" \
  >>"$NOTIFY_LOG"
exit 1
