#!/usr/bin/env bash
# nhq-await <session> [--timeout SECONDS] [--poll SECONDS] [--watch]
#   Block until a fleet agent reports back — WITHOUT reading as a failure when it
#   simply hasn't finished yet.
#
# THE missing return path. Director runs this (via its harness `run_in_background`)
# right after `nhq-spawn`. It blocks until the named session's agent calls
# `nhq-done` (which drops a fresh `~/.nhq-fleet/<session>.done` marker), then prints
# the captured report and exits 0 — so Director's harness fires a real completion
# notification instead of having to poll the inbox.
#
# ── Why the rewrite (the "everything shows FAILED" bug) ─────────────────────────
# The harness caps a background Bash command at 600000ms (10 min). The old default
# timeout here was 1500s (25 min) — so when Director watched a 30–45 min Fleet task,
# the harness SIGTERM-killed this watcher at 10 min, BEFORE it reached its own
# timeout branch. A killed bg process renders as a FAILED card. The old self-timeout
# path also exited 124 (= failed). Both produced false-failure signals while the
# agent work was succeeding underneath.
#
# Fix: a still-running poll is now a CLEAN, non-failure signal Director re-arms:
#   * default timeout 540s (9 min) — self-exits BEFORE the 10-min harness kill;
#   * own-timeout exits 0 (not 124) with a STILL-RUNNING status → re-arm;
#   * a SIGTERM/SIGINT trap turns any hard-kill into the same clean STILL-RUNNING/exit-0;
#   * genuine outcomes stay distinguishable via a stable final NHQ-AWAIT-STATUS line
#     AND exit code (below).
#
# ── Outcome contract (parse the final `NHQ-AWAIT-STATUS:` line) ─────────────────
#   REPORTED       exit 0   agent ran nhq-done; report printed   (real completion)
#   DONE           exit 0   alias of REPORTED (P3 typed outcome; DONE == REPORTED)
#   BLOCKED        exit 0   agent ran nhq-blocked; needs a human gate (NOT a failure)
#   STALLED        exit 0   warden flagged no-progress; Director fires Otto playbook-05
#   STILL-RUNNING  exit 0   own-timeout or hard-kill; RE-ARM     (NOT a failure)
#   WATCHING       exit 0   --watch handed off to a detached poller (see below)
#   GONE           exit 3   session crashed/killed, no report    (REAL failure)
#   ERROR          exit 1   bad usage
# Director: exit 0 + REPORTED/DONE   → fire the completion notification.
#           exit 0 + BLOCKED         → surface the gate to Yash; re-task once cleared.
#           exit 0 + STALLED         → fire Otto playbook-05 (STALLED-session recovery).
#           exit 0 + STILL-RUNNING   → just call nhq-await again (re-arm the watch).
#           exit 3 (GONE)            → alert: the agent died without reporting.
# Marker priority each poll: .blocked > .stalled > .done (a human gate / no-progress
# flag outranks a completion that may have been written first).
#
# Robustness (the "stale marker false-fire" bug): at arm time we RETIRE any marker
# older than a small grace window — a genuine report for THIS task cannot predate the
# arm by more than the Director re-arm hand-off, so an older marker is a leftover from
# a prior run (or a truncated/orphaned marker) and must never satisfy this await. A
# marker then counts as a real report only if it is no older than that grace window
# relative to arm. This keeps the invariant "an await armed now is NOT satisfied by a
# marker that existed before it was armed", while still catching a report that lands
# in the gap between one 9-min self-exit and Director re-arming the next nhq-await.
# Watching a per-session marker (not the shared inbox) avoids cross-agent false trips.
#
# Usage: nhq-await fleet-heydaddy-add-retry
#        nhq-await fleet-mirror-xyz --timeout 540
#        nhq-await fleet-heydaddy-long-task --watch   # detached, survives the cap
set -euo pipefail

SELF="$(readlink -f "${BASH_SOURCE[0]:-$0}")"
# shellcheck source=/dev/null
source "$(dirname "$SELF")/nhq-lib.sh"

SESSION="${1:-}"
shift || true
# Default 540s (9 min): self-exit cleanly BEFORE the 600s/10-min harness bg cap.
TIMEOUT=540
POLL=20        # seconds between checks
WATCH=0        # --watch => hand off to a detached poller that outlives the cap

while [[ $# -gt 0 ]]; do
  case "$1" in
    --timeout) TIMEOUT="${2:-540}"; shift 2 ;;
    --poll)    POLL="${2:-20}"; shift 2 ;;
    --watch)   WATCH=1; shift ;;
    *)         shift ;;
  esac
done

if [[ -z "$SESSION" ]]; then
  echo "usage: nhq-await <session> [--timeout SECONDS] [--poll SECONDS] [--watch]" >&2
  echo "NHQ-AWAIT-STATUS: ERROR"
  exit 1
fi

nhq_ensure_state_dir
MARKER="$(nhq_marker "$SESSION")"                    # .done  (nhq-done)
BLOCKED_MARKER="$NHQ_STATE_DIR/${SESSION}.blocked"   # .blocked (nhq-blocked)
STALLED_MARKER="$NHQ_STATE_DIR/${SESSION}.stalled"   # .stalled (nhq-warden)
START=$(date +%s)

# Re-arm hand-off tolerance (seconds): a report can land in the gap between one
# 9-min self-exit and Director re-arming a fresh nhq-await, so a marker written up
# to this long BEFORE we (re-)armed still counts as THIS task's report. Anything
# older is a stale leftover. Override with NHQ_AWAIT_ARM_GRACE if ever needed.
ARM_GRACE="${NHQ_AWAIT_ARM_GRACE:-120}"

# RETIRE a stale leftover marker at arm time: if a marker exists and is older than
# the grace window, it is from a prior run (or truncated/orphaned) and must never
# trip this await. Move it aside (best-effort; fall back to delete) and log it.
# P3: applies to all three typed markers (.done / .blocked / .stalled).
retire_stale() {
  local f="${1:-}"; [[ -f "$f" ]] || return 0
  local m; m=$(stat -c %Y "$f" 2>/dev/null || echo 0)
  if [[ $(( START - m )) -gt "$ARM_GRACE" ]]; then
    mv -f "$f" "${f}.stale-${START}" 2>/dev/null || rm -f "$f" 2>/dev/null || true
    echo "nhq-await: retired a stale leftover marker $(basename "$f") for $SESSION ($(( START - m ))s old at arm)" >&2
  fi
}
retire_stale "$MARKER"
retire_stale "$BLOCKED_MARKER"
retire_stale "$STALLED_MARKER"

# A marker counts as a real report only if it is no older than the grace window
# relative to arm — i.e. it landed at/after arm, or in the re-arm hand-off just
# before it. A pre-arm leftover (already retired above) can never satisfy this.
marker_fresh() {
  local f="${1:-}"; [[ -f "$f" ]] || return 1
  local m; m=$(stat -c %Y "$f" 2>/dev/null || echo 0)
  [[ $(( START - m )) -le "$ARM_GRACE" ]]
}
marker_is_fresh() { marker_fresh "$MARKER"; }   # back-compat: .done freshness
# Is ANY typed marker fresh (used to avoid a false GONE when a report just landed)?
any_marker_fresh() {
  marker_fresh "$BLOCKED_MARKER" || marker_fresh "$STALLED_MARKER" || marker_fresh "$MARKER"
}

# --watch: fork a setsid-detached poller that survives the harness 10-min cap,
# writes the report to <session>.await-result + fires a toast, then return now.
if [[ "$WATCH" == "1" ]]; then
  RESULT="$NHQ_STATE_DIR/${SESSION}.await-result"
  NOTIFY="$HOME/.local/bin/nhq-notify"
  # Detached poller: own session/process group, so a harness process-group kill of
  # the foreground watcher never reaches it. Polls up to ~1h.
  setsid bash -c '
    SESSION="'"$SESSION"'"; MARKER="'"$MARKER"'"; RESULT="'"$RESULT"'"
    BLOCKED_MARKER="'"$BLOCKED_MARKER"'"; STALLED_MARKER="'"$STALLED_MARKER"'"
    POLL="'"$POLL"'"; START="'"$START"'"; NOTIFY="'"$NOTIFY"'"; ARM_GRACE="'"$ARM_GRACE"'"
    WATCH_TIMEOUT=3600
    fresh() { [ -f "$1" ] || return 1; m=$(stat -c %Y "$1" 2>/dev/null || echo 0); [ $(( START - m )) -le "$ARM_GRACE" ]; }
    while :; do
      if fresh "$BLOCKED_MARKER"; then
        { echo "NHQ-AWAIT-STATUS: BLOCKED"; cat "$BLOCKED_MARKER"; } > "$RESULT"
        [ -x "$NOTIFY" ] && "$NOTIFY" needs-you "Fleet: $SESSION BLOCKED" "$(head -c 140 "$BLOCKED_MARKER")" || true
        exit 0
      fi
      if fresh "$STALLED_MARKER"; then
        { echo "NHQ-AWAIT-STATUS: STALLED"; cat "$STALLED_MARKER"; } > "$RESULT"
        [ -x "$NOTIFY" ] && "$NOTIFY" warn "Fleet: $SESSION STALLED" "$(head -c 140 "$STALLED_MARKER")" || true
        exit 0
      fi
      if fresh "$MARKER"; then
        { echo "NHQ-AWAIT-STATUS: REPORTED"; echo "NHQ-AWAIT-STATUS: DONE"; cat "$MARKER"; } > "$RESULT"
        [ -x "$NOTIFY" ] && "$NOTIFY" done "Fleet: $SESSION reported" "$(head -c 140 "$MARKER")" || true
        exit 0
      fi
      now=$(date +%s)
      [ $(( now - START )) -ge "$WATCH_TIMEOUT" ] && { echo "NHQ-AWAIT-STATUS: STILL-RUNNING (watch timeout)" > "$RESULT"; exit 0; }
      if ! tmux has-session -t "$SESSION" 2>/dev/null; then
        { fresh "$BLOCKED_MARKER" || fresh "$STALLED_MARKER" || fresh "$MARKER"; } && continue
        echo "NHQ-AWAIT-STATUS: GONE" > "$RESULT"
        [ -x "$NOTIFY" ] && "$NOTIFY" warn "Fleet: $SESSION GONE" "session died with no report" || true
        exit 0
      fi
      sleep "$POLL"
    done
  ' >/dev/null 2>&1 < /dev/null &
  disown 2>/dev/null || true
  echo "nhq-await: WATCHING $SESSION (detached poller; survives the 10-min cap)."
  echo "  result will land in: $RESULT  (+ desktop toast on completion/GONE)"
  echo "NHQ-AWAIT-STATUS: WATCHING"
  exit 0
fi

# Foreground blocking watch. A hard-kill (e.g. the harness 10-min cap, if a caller
# passed --timeout beyond it) is caught here and turned into a clean STILL-RUNNING
# re-arm signal rather than a FAILED card.
on_term() {
  echo
  echo "STILL-RUNNING — ${SESSION} has not reported yet (watcher terminated). Re-arm nhq-await."
  echo "NHQ-AWAIT-STATUS: STILL-RUNNING"
  exit 0
}
trap on_term TERM INT

echo "nhq-await: watching $SESSION (timeout ${TIMEOUT}s, poll ${POLL}s) for $MARKER"

while :; do
  # Typed markers, priority .blocked > .stalled > .done.
  if marker_fresh "$BLOCKED_MARKER"; then
    echo "── ${SESSION} BLOCKED — needs a human gate ──────────────────────"
    cat "$BLOCKED_MARKER"
    echo "─────────────────────────────────────────────────────────────────"
    echo "NHQ-AWAIT-STATUS: BLOCKED"
    exit 0
  fi
  if marker_fresh "$STALLED_MARKER"; then
    echo "── ${SESSION} STALLED — no progress (warden) ────────────────────"
    cat "$STALLED_MARKER"
    echo "─────────────────────────────────────────────────────────────────"
    echo "NHQ-AWAIT-STATUS: STALLED"
    exit 0
  fi
  if marker_is_fresh; then
    echo "── ${SESSION} reported ──────────────────────────────────────────"
    cat "$MARKER"
    echo "─────────────────────────────────────────────────────────────────"
    # REPORTED stays the back-compat terminal token; DONE is the P3 alias.
    echo "NHQ-AWAIT-STATUS: REPORTED"
    echo "NHQ-AWAIT-STATUS: DONE"
    exit 0
  fi

  now=$(date +%s)
  if [[ $(( now - START )) -ge "$TIMEOUT" ]]; then
    # Own timeout: NOT a failure — the agent is (almost certainly) still working.
    # Exit 0 with STILL-RUNNING so Director re-arms instead of seeing a FAILED card.
    state="$(nhq_session_state "$SESSION")"
    echo "STILL-RUNNING — ${SESSION} has not reported within ${TIMEOUT}s (under the 10-min harness cap)."
    echo "  state: $(nhq_state_badge "$state")"
    echo "  re-arm: nhq-await $SESSION   (or use --watch for a detached poller)"
    echo "  inspect: tmux attach -t $SESSION"
    echo "NHQ-AWAIT-STATUS: STILL-RUNNING"
    exit 0
  fi

  # If the session has gone DEAD with no fresh report, surface it as a REAL failure
  # (distinct from a still-running timeout) rather than blocking the full timeout.
  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    if any_marker_fresh; then continue; fi   # a typed marker just landed — let the loop top handle it
    echo "GONE — ${SESSION} no longer exists and left no report. It likely crashed or was killed."
    echo "NHQ-AWAIT-STATUS: GONE"
    exit 3
  fi

  sleep "$POLL"
done
