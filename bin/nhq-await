#!/usr/bin/env bash
# nhq-await <session> [--timeout SECONDS] — block until a fleet agent reports back.
#
# THE missing return path. Director runs this (via its harness `run_in_background`)
# right after `nhq-spawn`. It blocks until the named session's agent calls
# `nhq-done` (which drops a fresh `~/.nhq-fleet/<session>.done` marker), then prints
# the captured report and exits 0 — so Director's harness fires a real completion
# notification instead of having to poll the inbox.
#
# Robustness: it records its own start time and waits for a marker that is NEWER
# than start (mtime >= start). A stale marker from a previous run of a reused
# session therefore never false-trips it. Watching a per-session marker (not the
# shared inbox) also avoids cross-agent false trips when two agents run at once.
#
# Exit: 0 = report captured (printed to stdout). 124 = timed out. 1 = bad usage.
#
# Usage: nhq-await fleet-heydaddy-add-retry
#        nhq-await fleet-mirror-xyz --timeout 1800
set -euo pipefail

SELF="$(readlink -f "${BASH_SOURCE[0]:-$0}")"
# shellcheck source=/dev/null
source "$(dirname "$SELF")/nhq-lib.sh"

SESSION="${1:-}"
shift || true
TIMEOUT=1500   # default ~25 min
POLL=20        # seconds between checks

while [[ $# -gt 0 ]]; do
  case "$1" in
    --timeout) TIMEOUT="${2:-1500}"; shift 2 ;;
    --poll)    POLL="${2:-20}"; shift 2 ;;
    *)         shift ;;
  esac
done

if [[ -z "$SESSION" ]]; then
  echo "usage: nhq-await <session> [--timeout SECONDS]" >&2
  exit 1
fi

nhq_ensure_state_dir
MARKER="$(nhq_marker "$SESSION")"
START=$(date +%s)

echo "nhq-await: watching $SESSION (timeout ${TIMEOUT}s, poll ${POLL}s) for $MARKER"

# A marker counts only if it appeared/refreshed at or after we started waiting.
marker_is_fresh() {
  [[ -f "$MARKER" ]] || return 1
  local m; m=$(stat -c %Y "$MARKER" 2>/dev/null || echo 0)
  [[ "$m" -ge "$START" ]]
}

while :; do
  if marker_is_fresh; then
    echo "── ${SESSION} reported ──────────────────────────────────────────"
    cat "$MARKER"
    echo "─────────────────────────────────────────────────────────────────"
    exit 0
  fi

  now=$(date +%s)
  if [[ $(( now - START )) -ge "$TIMEOUT" ]]; then
    state="$(nhq_session_state "$SESSION")"
    echo "TIMEOUT — ${SESSION} did not report within ${TIMEOUT}s. Session may be stuck — check the pane:"
    echo "  state: $(nhq_state_badge "$state")"
    echo "  watch: tmux attach -t $SESSION"
    exit 124
  fi

  # If the session has gone DEAD with no fresh report, surface it early rather
  # than blocking the full timeout (claude crashed / was killed mid-task).
  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    if marker_is_fresh; then continue; fi
    echo "GONE — ${SESSION} no longer exists and left no report. It likely crashed or was killed."
    exit 1
  fi

  sleep "$POLL"
done
