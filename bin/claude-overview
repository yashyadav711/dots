#!/usr/bin/env python3
"""
claude-overview — live view of every Claude Code session/agent on this machine.

Per running session: project, model, git branch, turns, duration, total tokens
(incl. its sub-agents) and an estimated $ cost — plus a tree of its sub-agents and
what each is doing right now (read live from the transcripts), with the session's
last human prompt and last assistant action shown separately.

Usage:
  claude-overview            one-shot snapshot
  claude-overview -w [secs]  live refresh every <secs> (default 2) — Ctrl-C to quit
  claude-overview -a         include idle sessions (transcript untouched > 5 min)

stdlib only. Reads /proc + ~/.claude/projects/**/*.jsonl. Cost is a rough estimate
from public list prices, NOT billing truth. Lives in ~/Github/dots/bin (-> ~/.local/bin).
"""
import os, sys, json, time, glob, re, subprocess
from datetime import datetime

HOME = os.path.expanduser("~")
PROJECTS = os.path.join(HOME, ".claude", "projects")

# ── 5-hour usage window via ccusage (reads the same local *.jsonl) ────────────────
# Authoritative for "when does the rolling rate-limit window reset" + live burn rate.
# remainingMinutes = time left in the CURRENT 5h block (NOT quota left) — when it hits
# 0 the window rolls over and the Max allowance resets. Cached ~30s (ccusage = node,
# ~1s cold start) so watch mode stays cheap. Returns None if ccusage missing/no window.
_WIN_CACHE={"t":0.0,"val":None}
def usage_window():
    now=time.time()
    if now-_WIN_CACHE["t"]<30 and _WIN_CACHE["t"]:
        return _WIN_CACHE["val"]
    val=None
    try:
        out=subprocess.run(["ccusage","blocks","--json"],capture_output=True,
                           text=True,timeout=10).stdout
        d=json.loads(out); blocks=d.get("blocks",d) if isinstance(d,dict) else d
        for b in (blocks if isinstance(blocks,list) else []):
            if b.get("isActive"):
                proj=b.get("projection",{}) or {}
                br=b.get("burnRate",{}) or {}
                val={"rem":proj.get("remainingMinutes"),
                     "tpm":br.get("tokensPerMinute"),
                     "cost":b.get("costUSD")}
                break
    except Exception:
        val=None
    _WIN_CACHE["t"]=now; _WIN_CACHE["val"]=val
    return val

# ── ansi ────────────────────────────────────────────────────────────────────────
def c(s, code): return f"\033[{code}m{s}\033[0m"
BOLD="1"; DIM="2"; RED="31"; GREEN="32"; YELLOW="33"; BLUE="34"; MAGENTA="35"; CYAN="36"; GREY="90"
def clear(): sys.stdout.write("\033[2J\033[H")
_ansi=re.compile(r"\033\[[0-9;]*m")
def len_visible(s): return len(_ansi.sub("",s))
def pad_visible(s,width):
    return s+" "*max(0,width-len_visible(s))

# public API list prices per 1M tokens: (input, output, cache_read, cache_write_5m)
# source: platform.claude.com/docs/.../pricing — verified 2026-06-03 (PM-BT research).
# NOTE: the Pilot is on a Claude MAX subscription (flat ~$200/mo), NOT API billing — so
# the $ figure below is "API-equivalent" (what this token volume WOULD cost at API rates),
# not an actual charge. Token volume is the real signal; dollars are a reference only.
PRICING={"opus":(5.0,25.0,0.50,6.25),"sonnet":(3.0,15.0,0.30,3.75),"haiku":(1.0,5.0,0.10,1.25)}
def price_key(model):
    m=(model or "").lower()
    return "opus" if "opus" in m else "sonnet" if "sonnet" in m else "haiku" if "haiku" in m else "opus"

# ── /proc ─────────────────────────────────────────────────────────────────────────
def read_cmdline(pid):
    try:
        with open(f"/proc/{pid}/cmdline","rb") as f: return f.read().split(b"\0")
    except OSError: return []
def proc_cwd(pid):
    try: return os.readlink(f"/proc/{pid}/cwd")
    except OSError: return None
def proc_rss_mb(pid):
    try:
        with open(f"/proc/{pid}/statm") as f: pages=int(f.read().split()[1])
        return pages*os.sysconf("SC_PAGE_SIZE")/(1024*1024)
    except (OSError,IndexError,ValueError): return 0.0
def proc_age_s(pid):
    try: return max(0,time.time()-os.stat(f"/proc/{pid}").st_ctime)
    except OSError: return 0
def find_claude_procs():
    procs=[]
    for e in os.listdir("/proc"):
        if not e.isdigit(): continue
        argv=read_cmdline(e)
        if not argv: continue
        parts=[a.decode("utf-8","replace") for a in argv if a]
        if not parts or os.path.basename(parts[0])!="claude": continue
        kind="print-agent" if ("--print" in parts or "-p" in parts) else "session"
        pid=int(e)
        procs.append({"pid":pid,"kind":kind,"cwd":proc_cwd(pid),
                      "rss":proc_rss_mb(pid),"age":proc_age_s(pid)})
    return procs

# ── transcript scanning (incremental, cached across watch refreshes) ────────────────
def munge(path): return path.replace("/","-")
_STATS={}  # path -> accumulator (persists within a process, so watch mode is cheap)

def _new_acc(): return {"turns":0,"resp":0,"in":0,"out":0,"cr":0,"cw":0,
                        "model":None,"start":None,"last":None,"offset":0,"size":0}

def _process_line(d,acc):
    ts=d.get("timestamp")
    if ts:
        if acc["start"] is None: acc["start"]=ts
        acc["last"]=ts
    t=d.get("type"); m=d.get("message",{})
    if not isinstance(m,dict): return
    if t=="assistant":
        acc["resp"]+=1
        if m.get("model") and m["model"]!="<synthetic>": acc["model"]=m["model"]
        u=m.get("usage") or {}
        acc["in"]+=u.get("input_tokens",0) or 0
        acc["out"]+=u.get("output_tokens",0) or 0
        acc["cr"]+=u.get("cache_read_input_tokens",0) or 0
        acc["cw"]+=u.get("cache_creation_input_tokens",0) or 0
    elif t=="user":
        ct=m.get("content")
        human=isinstance(ct,str)
        if isinstance(ct,list):
            tr=any(isinstance(x,dict) and x.get("type")=="tool_result" for x in ct)
            tx=any(isinstance(x,dict) and x.get("type")=="text" for x in ct)
            human=tx and not tr
        if human: acc["turns"]+=1

def scan(path):
    """Return accumulated stats for a transcript, scanning only new bytes since last call."""
    try: st=os.stat(path)
    except OSError: return None
    acc=_STATS.get(path)
    if acc and acc["size"]==st.st_size: return acc
    if not acc or st.st_size<acc["size"]:           # new file, or truncated/rotated
        acc=_new_acc()
    start=acc["offset"]
    try:
        with open(path,"rb") as f:
            f.seek(start); data=f.read()
    except OSError: return acc
    text=data.decode("utf-8","replace")
    parts=text.split("\n")
    consumed=start
    for i,ln in enumerate(parts):
        if i==len(parts)-1 and not text.endswith("\n"): break   # incomplete trailing line
        consumed+=len(ln.encode("utf-8"))+1
        s=ln.strip()
        if not s: continue
        try: d=json.loads(s)
        except ValueError: continue
        _process_line(d,acc)
    acc["offset"]=consumed; acc["size"]=st.st_size
    _STATS[path]=acc
    return acc

def tail_lines(path,maxbytes=131072):
    try:
        sz=os.path.getsize(path)
        with open(path,"rb") as f:
            if sz>maxbytes: f.seek(sz-maxbytes)
            return f.read().decode("utf-8","replace").splitlines()
    except OSError: return []

def last_prompt_and_action(path):
    """(last human prompt, (icon,text) of last assistant/tool action)."""
    prompt=None; action=None
    for line in reversed(tail_lines(path)):
        s=line.strip()
        if not s: continue
        try: d=json.loads(s)
        except ValueError: continue
        t=d.get("type"); m=d.get("message",{})
        if action is None and t in ("assistant","user"):
            action=summarize(d)
        if prompt is None and t=="user" and isinstance(m,dict):
            ct=m.get("content")
            if isinstance(ct,str): prompt=ct.strip().replace("\n"," ")
            elif isinstance(ct,list):
                tr=any(isinstance(x,dict) and x.get("type")=="tool_result" for x in ct)
                if not tr:
                    for x in ct:
                        if isinstance(x,dict) and x.get("type")=="text" and x.get("text","").strip():
                            prompt=x["text"].strip().replace("\n"," "); break
        if prompt and action: break
    return prompt, action

def summarize(d):
    t=d.get("type"); m=d.get("message",{})
    ct=m.get("content") if isinstance(m,dict) else None
    if isinstance(ct,str):
        txt=ct.strip().replace("\n"," ")
        return ("👤","prompt: "+txt) if t=="user" else ("💬",txt)
    if isinstance(ct,list):
        for x in ct:
            if isinstance(x,dict) and x.get("type")=="tool_use":
                name=x.get("name","tool"); inp=x.get("input",{}); hint=""
                if isinstance(inp,dict):
                    for k in ("command","file_path","pattern","description","prompt","url","query","subagent_type"):
                        if inp.get(k): hint=str(inp[k]).replace("\n"," "); break
                return ("🔧",f"{name}: {hint}" if hint else name)
        for x in ct:
            if isinstance(x,dict) and x.get("type")=="text" and x.get("text","").strip():
                return ("💬",x["text"].strip().replace("\n"," "))
        for x in ct:
            if isinstance(x,dict) and x.get("type")=="tool_result":
                return ("⏳","got result, thinking…")
    return ("·","")

# ── formatting ─────────────────────────────────────────────────────────────────────
def fmt_age(s):
    s=int(s)
    if s<60: return f"{s}s"
    if s<3600: return f"{s//60}m"
    return f"{s//3600}h{(s%3600)//60}m"
def fmt_tok(n):
    if n>=1_000_000: return f"{n/1_000_000:.1f}M"
    if n>=1_000: return f"{n/1_000:.0f}k"
    return str(int(n))
def dot(age):
    if age<15: return c("●",GREEN)
    if age<120: return c("●",YELLOW)
    return c("○",GREY)
def parse_ts(s):
    if not s: return None
    try: return datetime.fromisoformat(s.replace("Z","+00:00")).timestamp()
    except (ValueError,AttributeError): return None
def short_model(m):
    return (m or "?").replace("claude-","").replace("-20"," "+"20"[:0])[:12] or "?"
def project_of_top(top):
    home=munge(HOME); ghpfx=home+"-Github-"
    if top.startswith(ghpfx): return top[len(ghpfx):]
    if top==home: return "~"
    if top.startswith(home+"-"): return top[len(home)+1:]
    return top.lstrip("-") or top
def trunc(s,n): return s if len(s)<=n else s[:n-1]+"…"
def row2(left,right,width):           # left-aligned + right-aligned to width (ANSI-aware)
    gap=width-len_visible(left)-len_visible(right)
    return left+" "*max(1,gap)+right
def label(lbl,text,lblcolor=DIM):     # aligned dim label + content
    return c("    "+lbl.ljust(7),lblcolor)+text
def money(cost):
    return ("~$%.0f"%cost) if cost>=10 else ("~$%.2f"%cost)

# ── model of a project/session ──────────────────────────────────────────────────────
def newest_transcripts_by_project():
    """project-dir-name -> [(mtime, path), ...] newest first (main-level transcripts only)."""
    by={}
    for jf in glob.glob(os.path.join(PROJECTS,"*","*.jsonl")):
        top=os.path.relpath(jf,PROJECTS).split(os.sep)[0]
        try: mt=os.path.getmtime(jf)
        except OSError: continue
        by.setdefault(top,[]).append((mt,jf))
    for k in by: by[k].sort(reverse=True)
    return by

def subagents_of(jf):
    sid=os.path.basename(jf)[:-6]            # strip .jsonl
    d=os.path.join(os.path.dirname(jf),sid,"subagents")
    if not os.path.isdir(d): return []
    now=time.time(); subs=[]
    for sf in glob.glob(os.path.join(d,"*.jsonl")):
        try: age=now-os.path.getmtime(sf)
        except OSError: continue
        subs.append((age,sf))
    return sorted(subs)

# ── render ────────────────────────────────────────────────────────────────────────
def render(include_idle=False, max_idle=300):
    W=78
    procs=find_claude_procs()
    sess=[p for p in procs if p["kind"]=="session"]
    agents=[p for p in procs if p["kind"]=="print-agent"]
    total_rss=sum(p["rss"] for p in procs)
    # project -> processes (for per-session RAM when unambiguous)
    proj_procs={}
    for p in procs:
        if p["cwd"]: proj_procs.setdefault(munge(p["cwd"]),[]).append(p)

    L=[]
    def box(inner): return c("│",CYAN)+pad_visible(inner,W)+c("│",CYAN)
    L.append(c("┌"+"─"*W+"┐",CYAN))
    L.append(box(f" {c('CLAUDE CODE',BOLD)} {c('· live overview',DIM)}"))
    L.append(box(f" {c('●',GREEN)} {len(sess)} session(s)    {c('◆',MAGENTA)} {len(agents)} background agent(s)    {c('Σ',DIM)} {total_rss:,.0f} MB RAM"))
    win=usage_window()
    if win and win.get("rem") is not None:
        rem=int(win["rem"]); h,m=divmod(rem,60); rs=(f"{h}h{m:02d}m" if h else f"{m}m")
        wcol=RED if rem<20 else YELLOW if rem<60 else GREEN
        tpm=win.get("tpm"); burn=c(f" · {tpm/1000:.0f}k tok/min",DIM) if tpm else ""
        L.append(box(f" {c('⧗',wcol)} {c('5h window resets in '+rs,wcol)}{burn}"))
    L.append(c("└"+"─"*W+"┘",CYAN))

    L.append(c(" SESSIONS",BOLD)+c("   (one block per running claude process)",DIM))
    by=newest_transcripts_by_project()
    used=set(); now=time.time()
    # one block per running session/agent process, most-recently-active first
    def proc_age_for_sort(p):
        top=munge(p["cwd"]) if p["cwd"] else ""
        for mt,jf in by.get(top,[]):
            if jf not in used: return now-mt
        return 9e9
    order=sorted(sess+agents, key=proc_age_for_sort)
    if not order:
        L.append(c("  (no running claude processes)",DIM))
    for p in order:
        top=munge(p["cwd"]) if p["cwd"] else ""
        proj=project_of_top(top) if top else "?"
        jf=None
        for mt,cand in by.get(top,[]):
            if cand not in used: jf=cand; used.add(cand); break
        tag=c(" ◆bg",MAGENTA) if p["kind"]=="print-agent" else ""
        if not jf:
            L.append(f" {c('○',GREY)} {c(proj,BOLD)}{tag}  {c('(no transcript yet)  %s  %.0fMB'%(fmt_age(p['age']),p['rss']),DIM)}")
            continue
        age=now-mt
        st=scan(jf) or _new_acc()
        subs=subagents_of(jf)
        tin,tout,tcr,tcw=st["in"],st["out"],st["cr"],st["cw"]; model=st["model"]
        for _,sf in subs:
            sa=scan(sf)
            if sa: tin+=sa["in"];tout+=sa["out"];tcr+=sa["cr"];tcw+=sa["cw"];model=model or sa["model"]
        pin,pout,pcr,pcw=PRICING[price_key(model)]
        cost=(tin*pin+tout*pout+tcr*pcr+tcw*pcw)/1e6
        io=tin+tout
        # "up" = how long THIS process has been alive (truthful), not the resumed-conversation calendar span.
        # conversation calendar span shown dim as "·Xold" when it's much longer than uptime (i.e. resumed).
        sts=parse_ts(st["start"]); lts=parse_ts(st["last"])
        span=((lts or now)-sts) if sts else 0
        spantag=c(f" ·{fmt_age(span)} convo",DIM) if span>p["age"]+600 else ""
        branch=""
        for line in reversed(tail_lines(jf,8192)):
            try: branch=(json.loads(line).get("gitBranch") or ""); break
            except Exception: continue
        # ── header row: ● project ......................... model · up Xh
        bgtag=c("◆ bg · ",MAGENTA) if p["kind"]=="print-agent" else ""
        left=f" {dot(age)}  {c(proj,BOLD)}"
        right=f"{bgtag}{c(short_model(model) if model else '—',BLUE)} · up {fmt_age(p['age'])}{spantag}"
        L.append(row2(left,right,W))
        # ── detail rows (aligned labels)
        prompt,action=last_prompt_and_action(jf)
        showprompt = prompt and not prompt.lstrip().startswith("<")   # skip noisy task/system tags
        if showprompt:
            L.append(label("prompt",trunc(prompt,W-12)))
        if action and not (action[0]=="👤" and showprompt):           # don't echo the prompt as "now"
            L.append(label("now",f"{action[0]} {trunc(action[1],W-14)}"))
        L.append(label("stats",
            f"{st['turns']} turns · {fmt_tok(io)} io · {c(money(cost)+' api-eq',GREEN)} · {p['rss']:.0f}MB · {branch or '-'}"))
        # ── agent tree
        live=subs if include_idle else [s for s in subs if s[0]<max_idle]
        for i,(sage,sf) in enumerate(live):
            tee="└" if i==len(live)-1 else "├"
            _,sact=last_prompt_and_action(sf)
            aid=os.path.basename(sf).replace("agent-","")[:8]
            txt=f"{sact[0]} {sact[1]}" if sact else ""
            L.append(label("agents" if i==0 else "",
                f"{c(tee,GREY)} {dot(sage)} {c(aid,CYAN)} {trunc(txt,W-27)} {c(fmt_age(sage),DIM)}"))
        L.append("")    # blank line between sessions
    L.append(c(" ⧗=time until the rolling 5h rate-limit window resets (via ccusage) — not quota remaining",DIM))
    L.append(c(" up=process uptime · convo=conversation span (resumed) · io=fresh in+out tokens",DIM))
    L.append(c(" api-eq=API-equivalent $ at list price (incl cache + sub-agents) — Pilot is on MAX flat-rate, NOT billed this",DIM))
    return "\n".join(L)

def main():
    args=sys.argv[1:]; watch=False; interval=2.0; idle=False; i=0
    while i<len(args):
        a=args[i]
        if a in ("-w","--watch"):
            watch=True
            if i+1<len(args) and args[i+1].replace(".","",1).isdigit(): interval=float(args[i+1]); i+=1
        elif a in ("-a","--all"): idle=True
        elif a in ("-h","--help"): print(__doc__); return
        i+=1
    if not watch: print(render(idle)); return
    try:
        while True:
            clear(); print(render(idle))
            print(c(f"\n  refreshing every {interval:g}s · Ctrl-C to quit",DIM)); time.sleep(interval)
    except KeyboardInterrupt: print()

if __name__=="__main__": main()
