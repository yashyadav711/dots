#!/usr/bin/env bash
# nhq-fleet — dashboard of every live NHQ fleet agent.
#
# P2: this is now a thin alias over `nhq-status`, the single fleet-state surface.
#   nhq-fleet            → nhq-status --human   (dashboard + tokens/cost per session)
#   nhq-fleet --json     → nhq-status --json    (Control Center feed)
#   nhq-fleet --no-reap  → nhq-status --human --no-reap   (skip the opportunistic reap)
# nhq-status defaults to --human, so a bare `nhq-fleet` renders the dashboard; an
# explicit mode flag (e.g. --json) overrides it. All state/repo/usage resolution
# now lives in nhq-status + nhq-lib (registry + .meta), not here.
set -euo pipefail

SELF="$(readlink -f "${BASH_SOURCE[0]:-$0}")"
exec "$(dirname "$SELF")/nhq-status" "$@"
