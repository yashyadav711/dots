#!/usr/bin/env bash
# nhq-goal — per-session budget guard for the NHQ Fleet Kit (OBSERVE + WARN only).
#
# The deferred v1 "nhq-goal budgets" capability. It records a per-session token / USD
# ceiling and, on `check`, compares the session's ACTUAL spend against that ceiling
# and reports ok | warn (>=80%) | exceeded (>=100%). It is deliberately TOOTHLESS:
# it NEVER kills, pauses, or signals an agent. It only prints state and sets an exit
# code so a caller MAY react (e.g. a warden could nudge) — the safety call is theirs.
#
# Spend source (read-only): a session's spend is whatever nhq-cost has already
# persisted into the session's .meta record (tokens_in/tokens_out + cost_usd), read
# back via nhq-meta. nhq-goal NEVER recomputes or mutates .meta — it only reads.
#
# Budgets live in $NHQ_STATE_DIR/goals.json (override with $NHQ_GOALS), a flat map
# of session -> { tokens, usd, set_at }; either dimension may be null (unset).
#
# Usage:
#   nhq-goal set   <session> [--tokens N] [--usd X]   # record a ceiling (>=1 of the two)
#   nhq-goal check <session> [--json]                 # compare spend vs ceiling -> state
#                                                     #   exit 0 ok|warn, 1 exceeded
#   nhq-goal list  [--json]                           # show every recorded budget
#   nhq-goal clear <session>                          # forget a session's budget
set -uo pipefail

# Data home: honor the kit's NHQ_STATE_DIR, accept NHQ_FLEET_HOME as an alias, and
# EXPORT it so the nhq-meta child reads the same dir. nhq-lib.sh keeps a pre-set value.
: "${NHQ_STATE_DIR:=${NHQ_FLEET_HOME:-$HOME/.nhq-fleet}}"
export NHQ_STATE_DIR

SELF="$(readlink -f "${BASH_SOURCE[0]:-$0}")"
# shellcheck source=/dev/null
source "$(dirname "$SELF")/nhq-lib.sh"
META_BIN="$(dirname "$SELF")/nhq-meta"

GOALS="${NHQ_GOALS:-$NHQ_STATE_DIR/goals.json}"

die() { echo "nhq-goal: $*" >&2; exit 1; }

command -v jq >/dev/null 2>&1 || die "jq not found (install: sudo pacman -S jq)"

is_uint() { [[ "$1" =~ ^[0-9]+$ ]]; }
is_num()  { [[ "$1" =~ ^[0-9]+([.][0-9]+)?$ ]]; }

# Ensure the goals map exists as a well-formed JSON object.
ensure_goals() { nhq_ensure_state_dir; [[ -s "$GOALS" ]] || echo '{}' > "$GOALS"; }

# Atomic jq write on $GOALS (mirror of nhq-meta's _meta_atomic): land via tmpfile+mv
# so a concurrent reader never sees a half-written map.
goals_atomic() {
  local tmp; tmp="$(mktemp "${GOALS}.XXXXXX")"
  if jq "$@" "$GOALS" > "$tmp" 2>/dev/null; then
    mv -f "$tmp" "$GOALS"
  else
    rm -f "$tmp"; die "jq write failed on $GOALS"
  fi
}

# Read one persisted spend field from a session's .meta via nhq-meta (read-only).
# Absent record/field -> "" (caller defaults to 0). nhq-meta get dies if no .meta;
# swallow that so a session with no spend yet simply reads as 0.
meta_field() { "$META_BIN" get "$1" "$2" 2>/dev/null || true; }

# tokens spend = tokens_in + tokens_out (the cumulative counters nhq-cost persists).
spend_tokens() {
  local ti to; ti="$(meta_field "$1" tokens_in)"; to="$(meta_field "$1" tokens_out)"
  awk -v a="${ti:-0}" -v b="${to:-0}" 'BEGIN{ printf "%d", a + b }'
}
# usd spend = cost_usd (nhq-cost's list-price estimate).
spend_usd() { local c; c="$(meta_field "$1" cost_usd)"; printf '%s' "${c:-0}"; }

# dim_state SPEND BUDGET -> "state pct" (ok|warn|exceeded + percent, 1 dp).
# warn at >=80%, exceeded at >=100%. Budget <=0/empty is never passed here.
dim_state() {
  awk -v s="$1" -v b="$2" 'BEGIN{
    p = (s / b) * 100;
    st = "ok"; if (p >= 100) st = "exceeded"; else if (p >= 80) st = "warn";
    printf "%s %.1f", st, p
  }'
}

usage() { sed -n '17,22p' "$SELF" | sed 's/^# \{0,1\}//'; }

cmd="${1:-}"; shift || true

case "$cmd" in
  set)
    session="${1:-}"; shift || true
    [[ -z "$session" ]] && die "usage: nhq-goal set <session> [--tokens N] [--usd X]"
    tok=""; usd=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --tokens) [[ $# -ge 2 ]] || die "--tokens needs a value"; tok="$2"; shift 2 ;;
        --usd)    [[ $# -ge 2 ]] || die "--usd needs a value";    usd="$2"; shift 2 ;;
        *) die "set: unknown arg '$1' (want --tokens N / --usd X)" ;;
      esac
    done
    [[ -z "$tok" && -z "$usd" ]] && die "set: need at least one of --tokens N / --usd X"
    tok_arg=null; usd_arg=null
    if [[ -n "$tok" ]]; then
      is_uint "$tok" && [[ "$tok" -gt 0 ]] || die "--tokens must be a positive integer"
      tok_arg="$tok"
    fi
    if [[ -n "$usd" ]]; then
      is_num "$usd" && awk -v x="$usd" 'BEGIN{exit !(x > 0)}' || die "--usd must be a positive number"
      usd_arg="$usd"
    fi
    ensure_goals
    ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    # Merge: only the supplied dimension(s) change; the other is preserved (or stays
    # null on a fresh entry). set_at always refreshes to mark the latest change.
    goals_atomic --arg s "$session" --arg ts "$ts" --argjson tok "$tok_arg" --argjson usd "$usd_arg" '
      .[$s] = ( (.[$s] // {})
                + (if $tok != null then {tokens: $tok} else {} end)
                + (if $usd != null then {usd:    $usd} else {} end)
                + {set_at: $ts} )'
    echo "nhq-goal: set $session  tokens=${tok:--}  usd=${usd:--}"
    ;;

  check)
    json=0
    if [[ "${1:-}" == "--json" ]]; then json=1; shift; fi
    session="${1:-}"
    [[ -z "$session" ]] && die "usage: nhq-goal check <session> [--json]"

    tok_budget=""; usd_budget=""; set_at=""; have_entry="false"
    if [[ -s "$GOALS" ]]; then
      have_entry="$(jq -r --arg s "$session" 'has($s)' "$GOALS" 2>/dev/null || echo false)"
      tok_budget="$(jq -r --arg s "$session" '.[$s].tokens // empty' "$GOALS" 2>/dev/null)"
      usd_budget="$(jq -r --arg s "$session" '.[$s].usd    // empty' "$GOALS" 2>/dev/null)"
      set_at="$(jq -r --arg s "$session" '.[$s].set_at  // empty' "$GOALS" 2>/dev/null)"
    fi

    rank=0; combined="ok"
    bump() { local r=0; case "$1" in ok) r=0 ;; warn) r=1 ;; exceeded) r=2 ;; esac
             if [[ $r -gt $rank ]]; then rank=$r; combined="$1"; fi; }

    tok_spend=0; tok_state=""; tok_pct=0
    usd_spend=0; usd_state=""; usd_pct=0
    if [[ -n "$tok_budget" ]]; then
      tok_spend="$(spend_tokens "$session")"
      read -r tok_state tok_pct <<<"$(dim_state "$tok_spend" "$tok_budget")"
      bump "$tok_state"
    fi
    if [[ -n "$usd_budget" ]]; then
      usd_spend="$(spend_usd "$session")"
      read -r usd_state usd_pct <<<"$(dim_state "$usd_spend" "$usd_budget")"
      bump "$usd_state"
    fi

    # No budget recorded for this session -> nothing to enforce.
    if [[ "$have_entry" != "true" || ( -z "$tok_budget" && -z "$usd_budget" ) ]]; then
      combined="unset"
    fi

    if [[ "$json" == "1" ]]; then
      jq -n \
        --arg s "$session" --arg st "$combined" --arg sat "$set_at" \
        --argjson tb "${tok_budget:-null}" --argjson tsp "$tok_spend" --argjson tp "$tok_pct" --arg tst "$tok_state" \
        --argjson ub "${usd_budget:-null}" --argjson usp "$usd_spend" --argjson up "$usd_pct" --arg ust "$usd_state" '
        {session: $s, state: $st}
        + (if $sat != "" then {set_at: $sat} else {} end)
        + (if $tb != null then {tokens: {budget: $tb, spend: $tsp, pct: $tp, state: $tst}} else {} end)
        + (if $ub != null then {usd:    {budget: $ub, spend: $usp, pct: $up, state: $ust}} else {} end)'
    else
      if [[ "$combined" == "unset" ]]; then
        echo "nhq-goal: $session  (no budget set)"
      else
        echo "nhq-goal: $session"
        [[ -n "$tok_budget" ]] && printf '  tokens  %s / %s  (%s%%)  %s\n' "$tok_spend" "$tok_budget" "$tok_pct" "$tok_state"
        [[ -n "$usd_budget" ]] && printf '  usd     %.2f / %.2f  (%s%%)  %s\n' "$usd_spend" "$usd_budget" "$usd_pct" "$usd_state"
        printf '  -> %s\n' "$combined"
      fi
    fi

    [[ "$combined" == "exceeded" ]] && exit 1 || exit 0
    ;;

  list)
    json=0
    if [[ "${1:-}" == "--json" ]]; then json=1; fi
    if [[ ! -s "$GOALS" ]]; then
      [[ "$json" == "1" ]] && echo '{}' || echo "nhq-goal: no budgets set"
      exit 0
    fi
    if [[ "$json" == "1" ]]; then
      jq '.' "$GOALS"
    else
      printf '%-28s %14s %10s  %s\n' SESSION TOKENS USD SET_AT
      jq -r 'to_entries[] | [.key, (.value.tokens // "-"|tostring), (.value.usd // "-"|tostring), (.value.set_at // "-")] | @tsv' "$GOALS" \
        | while IFS=$'\t' read -r s t u a; do printf '%-28s %14s %10s  %s\n' "$s" "$t" "$u" "$a"; done
    fi
    ;;

  clear)
    session="${1:-}"
    [[ -z "$session" ]] && die "usage: nhq-goal clear <session>"
    ensure_goals
    if [[ "$(jq -r --arg s "$session" 'has($s)' "$GOALS" 2>/dev/null)" != "true" ]]; then
      echo "nhq-goal: no budget for '$session'"
      exit 0
    fi
    goals_atomic --arg s "$session" 'del(.[$s])'
    echo "nhq-goal: cleared $session"
    ;;

  ""|-h|--help|help)
    usage
    ;;

  *)
    die "unknown command '$cmd' (want: set|check|list|clear)"
    ;;
esac
