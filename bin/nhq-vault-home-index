#!/usr/bin/env python3
"""nhq-vault-home-index — rebuild the auto doc-index block in the nHQ vault Home.md.

The vault Home is the first thing Yash opens, so it must NEVER be stale: this
regenerates the `<!-- DOC-INDEX:START ... DOC-INDEX:END -->` block in place with
the 40 most-recently-modified notes shown + the full list collapsed. Idempotent —
safe to run on every session start (wired into the gm/session-start vault sync).

Usage: nhq-vault-home-index            # rebuild + print a one-line summary
"""
import datetime
from pathlib import Path

VAULT = Path("/home/yash/Github/product-manager/Yash's Folder/Obsidian/nHQ")
HOME = VAULT / "Home.md"
RECENT_N = 40
EXCLUDE_TOP = {".obsidian", "_Read"}

def excluded(rel: Path) -> bool:
    parts = rel.parts
    return (bool(parts) and parts[0] in EXCLUDE_TOP) or ("nhq-kit" in parts) or rel.name == "Home.md"

def row(mt: float, rel: Path) -> str:
    ts = datetime.datetime.fromtimestamp(mt).strftime("%Y-%m-%d %H:%M")
    folder = str(rel.parent) if str(rel.parent) != "." else "(root)"
    return f"- `{ts}` — [[{rel.with_suffix('')}|{rel.stem}]] · *{folder}*"

def main() -> None:
    docs = []
    for p in VAULT.rglob("*.md"):
        rel = p.relative_to(VAULT)
        if excluded(rel):
            continue
        try:
            docs.append((p.stat().st_mtime, rel))
        except OSError:
            pass
    docs.sort(key=lambda x: x[0], reverse=True)
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M")

    lines = [
        "<!-- DOC-INDEX:START — auto-generated by nhq-vault-home-index; do not hand-edit between the markers. -->",
        "## 🗂️ Documents — by date (newest first)",
        "",
        f"> [!info]+ {len(docs)} notes · refreshed {now} · top {RECENT_N} shown, full list collapsed",
        f"> The vault's live index — regenerated every session start so it's never stale.",
        "",
        f"**🔥 {RECENT_N} most recently updated**",
        *[row(mt, rel) for mt, rel in docs[:RECENT_N]],
        "",
        "<details>",
        f"<summary>📚 All {len(docs)} notes — by date</summary>",
        "",
        *[row(mt, rel) for mt, rel in docs],
        "",
        "</details>",
        "",
        "<!-- DOC-INDEX:END -->",
    ]
    block = "\n".join(lines)

    txt = HOME.read_text(encoding="utf-8")
    START, END = "<!-- DOC-INDEX:START", "<!-- DOC-INDEX:END -->"
    if START in txt and END in txt:
        pre = txt[: txt.index(START)]
        post = txt[txt.index(END) + len(END):].lstrip("\n")
        HOME.write_text(pre + block + "\n" + post, encoding="utf-8")
        where = "replaced existing block"
    else:  # markers gone — insert before the first "## " section, else append
        anchor = "\n## "
        i = txt.find(anchor)
        if i == -1:
            HOME.write_text(txt.rstrip() + "\n\n" + block + "\n", encoding="utf-8")
            where = "appended (no markers found)"
        else:
            HOME.write_text(txt[:i] + "\n" + block + "\n" + txt[i:], encoding="utf-8")
            where = "inserted (markers were missing)"
    print(f"nhq-vault-home-index: {where}; {len(docs)} notes, top {RECENT_N} shown")

if __name__ == "__main__":
    main()
